+    private static EntityFakePlayer.Mode toNmsMode(Mode mode) {
+        switch (mode) {
+            case NPC:    return EntityFakePlayer.Mode.NPC;
+            case NO_AI:  return EntityFakePlayer.Mode.NO_AI;
+            case COMBAT: return EntityFakePlayer.Mode.COMBAT;
+            default: throw new IllegalArgumentException("Unknown mode: " + mode);
+        }
+    }
+
+    private static Mode fromNmsMode(EntityFakePlayer.Mode mode) {
+        switch (mode) {
+            case NPC:    return Mode.NPC;
+            case NO_AI:  return Mode.NO_AI;
+            case COMBAT: return Mode.COMBAT;
+            default: throw new IllegalArgumentException("Unknown mode: " + mode);
+        }
+    }
