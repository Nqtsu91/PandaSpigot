+
+    /** No-op: fake players don't reset statistics. */
+    @Override
+    public void a(Statistic statistic) { /* no-op */ }
+
+    /** No-op: skip the biome-exploration achievement check every second. */
+    @Override
+    protected void i_() { /* no-op */ }
+
+    // ─────────────────────────────────────────────────────────────────────────
+    // Skin helpers (private)
+    // ─────────────────────────────────────────────────────────────────────────
+
+    /**
+     * Replaces the {@code "textures"} property in this bot's {@link GameProfile}
+     * with the current {@link #skinTextureValue} / {@link #skinSignature} pair.
+     * When {@code skinTextureValue} is {@code null} the property is removed,
+     * restoring the default appearance.
+     *
+     * <p>Call this after updating any skin field, then {@link #refreshTracking()}
+     * to propagate the change to already-connected observers.</p>
+     */
+    private void applySkinToProfile() {
+        GameProfile profile = this.getProfile();
+        profile.getProperties().removeAll("textures");
+        if (skinTextureValue != null) {
+            Property prop = (skinSignature != null)
+                    ? new Property("textures", skinTextureValue, skinSignature)
+                    : new Property("textures", skinTextureValue);
+            profile.getProperties().put("textures", prop);
+        }
+    }
+
+    /**
+     * Forces the entity tracker to re-send the spawn packet for this bot to all
+     * currently tracking players, so they immediately see any profile changes
+     * (skin, name, etc.).
+     *
+     * <p>This triggers a brief visual flicker (destroy + respawn) for observers.
+     * It is a no-op when the bot is dead or has not yet been added to the world.</p>
+     */
+    private void refreshTracking() {
+        if (!(this.world instanceof WorldServer) || this.dead) return;
+        EntityTracker tracker = ((WorldServer) this.world).tracker;
+        tracker.untrackEntity(this);
+        tracker.track(this);
+    }
+
+    // ─────────────────────────────────────────────────────────────────────────
+    // Public API (used by FakePlayerManager)
+    // ─────────────────────────────────────────────────────────────────────────
+
+    /** Returns the current operating mode. */
+    public Mode getFakeMode() {
+        return mode;
+    }
+
+    /**
+     * Sets the operating mode.
+     * Switching to {@link Mode#NPC} clears the target and stops movement.
+     */
+    public void setFakeMode(Mode mode) {
+        this.mode = mode;
+        if (mode == Mode.NPC || mode == Mode.NO_AI) {
+            this.combatTarget = null;
+            this.motX = 0.0;
+            this.motZ = 0.0;
+            this.setSprinting(false);
+            if (waterPhase > 0) cancelWater();
+            if (eatTicks   > 0) cancelEating();
+        }
+    }
+
+    /** Returns the current combat target, or {@code null} if none. */
+    public EntityLiving getCombatTarget() {
+        return combatTarget;
+    }
+
+    /**
+     * Sets the combat target.  Automatically switches to {@link Mode#COMBAT}
+     * if {@code target} is non-null.
+     */
+    public void setCombatTarget(EntityLiving target) {
+        this.combatTarget = target;
+        if (target != null) {
+            this.mode = Mode.COMBAT;
+            this.attackCooldown = 0;
+        }
+    }
+
+    /** Returns the number of golden apples remaining. */
+    public int getGappleCount() {
+        return gappleCount;
+    }
+
+    /**
+     * Sets the number of golden apples available.
+     *
+     * @param count non-negative apple count
+     */
+    public void setGappleCount(int count) {
+        this.gappleCount = Math.max(0, count);
+    }
+
+    /**
+     * Returns {@code true} while the bot is in the middle of eating a golden
+     * apple (i.e. during the {@link #EAT_DURATION_TICKS}-tick eating animation).
+     */
+    public boolean isEating() {
+        return eatTicks > 0;
+    }
+
+    /**
+     * Returns {@code true} while a water-clutch sequence is in progress
+     * (bucket hold + place + remove).
+     */
+    public boolean isPlacingWater() {
+        return waterPhase > 0;
+    }
+
+    /**
+     * Returns the ticks remaining before the next water clutch is allowed.
+     * 0 means the bot can clutch immediately (subject to fire and ground checks).
+     */
+    public int getWaterCooldown() {
+        return waterCooldown;
+    }
+
+    /**
+     * Force-resets the water-clutch cooldown so the bot can extinguish itself
+     * on the next fire tick without waiting.
+     */
+    public void resetWaterCooldown() {
+        this.waterCooldown = 0;
+    }
+
+    /** Returns {@code true} if this bot is allowed to use water to extinguish itself. */
+    public boolean isWaterEnabled() {
+        return waterEnabled;
+    }
+
+    /**
+     * Enables or disables the water-clutch self-extinguish mechanic.
+     *
+     * @param enabled {@code false} to prevent the bot from ever placing water
+     */
+    public void setWaterEnabled(boolean enabled) {
+        this.waterEnabled = enabled;
+        if (!enabled && (waterPhase > 0 || waterPos != null)) cancelWater();
+    }
+
+    /**
+     * Returns the per-bot cooldown between water clutches in ticks.
+     * Default: 100 ticks (5 s).
+     */
+    public int getWaterCooldownDuration() {
+        return waterCooldownDuration;
+    }
+
+    /**
+     * Sets the cooldown between water clutches for this bot specifically.
+     *
+     * @param ticks non-negative tick count; 0 means no cooldown between clutches
+     */
+    public void setWaterCooldownDuration(int ticks) {
+        this.waterCooldownDuration = Math.max(0, ticks);
+    }
+
+    /**
+     * Returns the ticks the water block stays active when the bot is in lava.
+     * Default: 60 ticks (3 s).
+     */
+    public int getWaterLavaStayTicks() {
+        return waterLavaStayTicks;
+    }
+
+    /**
+     * Sets how long (in ticks) the water source block stays on the ground when
+     * the bot's feet or head are in lava.
+     *
+     * <p>Increase this value for deep lava pools; the bot needs enough contact
+     * time with water to extinguish and swim out before the source is removed.</p>
+     *
+     * @param ticks non-negative tick count; minimum effective value is 1
+     */
+    public void setWaterLavaStayTicks(int ticks) {
+        this.waterLavaStayTicks = Math.max(1, ticks);
+    }
+
+    // ─────────────────────────────────────────────────────────────────────────
+    // Reach
+    // ─────────────────────────────────────────────────────────────────────────
+
+    /**
+     * Returns the current melee reach of this bot in blocks (default 3.5).
+     *
+     * @return reach in blocks (always positive)
+     */
+    public double getAttackRange() {
+        return Math.sqrt(attackRangeSq);
+    }
+
+    /**
+     * Sets the per-clone melee reach.
+     *
+     * <p>Changes take effect on the next tick.  Also widens or narrows the
+     * "out-of-range" window used by the swimming and airborne movement phases,
+     * so the bot starts closing distance to the target sooner or later.</p>
+     *
+     * <p><b>Impact CPU :</b> none — the reach only changes the squared-distance
+     * comparison in {@code tryAttack()} and {@code moveTowardTarget()}, both O(1).
+     * <b>Compatibilité plugins :</b> server-side only; client-side reach checks for
+     * real players are unaffected.</p>
+     *
+     * @param blocks positive reach in blocks; clamped to [0.5, 20]
+     */
+    public void setAttackRange(double blocks) {
+        double clamped = Math.max(0.5, Math.min(20.0, blocks));
+        this.attackRangeSq = clamped * clamped;
+    }
+
+    // ─────────────────────────────────────────────────────────────────────────
+    // Skin
+    // ─────────────────────────────────────────────────────────────────────────
+
+    /**
+     * Installs a custom skin from a Minecraft texture URL.
+     *
+     * <p>Builds and Base64-encodes the textures JSON internally:</p>
+     * <pre>
+     * {"textures":{"SKIN":{"url":"&lt;skinUrl&gt;"[,"metadata":{"model":"slim"}]}
+     *             [,"CAPE":{"url":"&lt;capeUrl&gt;"}]}}
+     * </pre>
+     *
+     * <p>Because no Mojang signature is generated here, the skin is unsigned.
+     * This works on most Bungeecord / offline servers.  For online-mode servers
+     * fetch a signed property from the Mojang session API and use
+     * {@link #setSkinRaw(String, String)} instead.</p>
+     *
+     * <p>If the bot is already in the world, nearby observers will see the skin
+     * change immediately (brief despawn + respawn flicker).</p>
+     *
+     * @param skinUrl  Minecraft texture URL,
+     *                 e.g. {@code "http://textures.minecraft.net/texture/abc123"}
+     * @param slim     {@code true} for the Alex (slim-arms) model,
+     *                 {@code false} for Steve
+     * @param capeUrl  Cape texture URL, or {@code null} / {@code ""} for no cape
+     */
+    public void setSkin(String skinUrl, boolean slim, String capeUrl) {
+        if (skinUrl == null || skinUrl.isEmpty()) {
+            clearSkin();
+            return;
+        }
+        // Build the textures JSON manually — no external JSON lib needed.
+        StringBuilder json = new StringBuilder(128);
+        json.append("{\"textures\":{\"SKIN\":{\"url\":\"").append(skinUrl).append("\"");
+        if (slim) {
+            json.append(",\"metadata\":{\"model\":\"slim\"}");
+        }
+        json.append("}");
+        if (capeUrl != null && !capeUrl.isEmpty()) {
+            json.append(",\"CAPE\":{\"url\":\"").append(capeUrl).append("\"}");
+        }
+        json.append("}}");
+
+        this.skinSlimModel   = slim;
+        this.capeTextureUrl  = (capeUrl != null && !capeUrl.isEmpty()) ? capeUrl : null;
+        this.skinSignature   = null; // unsigned
+        this.skinTextureValue = Base64.getEncoder().encodeToString(
+                json.toString().getBytes(StandardCharsets.UTF_8));
+
+        applySkinToProfile();
+        refreshTracking();
+    }
+
+    /**
+     * Installs a pre-signed skin profile property obtained from the Mojang
+     * session API (e.g. via {@code GET /session/minecraft/profile/<uuid>?unsigned=false}).
+     *
+     * <p>Use this when the server runs in online mode and clients verify the
+     * Mojang signature.  The {@code value} is the Base64-encoded textures JSON
+     * already returned by the API, and {@code signature} is the RSA-SHA1 signature
+     * also returned by the API.</p>
+     *
+     * <p>Pass {@code null} as {@code signature} to install the property unsigned
+     * (works the same as {@link #setSkin(String, boolean, String)} from the game's
+     * perspective).</p>
+     *
+     * @param value     Base64-encoded textures JSON (from Mojang API {@code value} field)
+     * @param signature RSA-SHA1 signature (from Mojang API {@code signature} field),
+     *                  or {@code null}
+     */
+    public void setSkinRaw(String value, String signature) {
+        if (value == null || value.isEmpty()) {
+            clearSkin();
+            return;
+        }
+        this.skinTextureValue = value;
+        this.skinSignature    = signature;
+        // Cannot infer slim/cape from raw value without decoding JSON — leave as-is.
+        applySkinToProfile();
+        refreshTracking();
+    }
+
+    /**
+     * Removes the custom skin, restoring the default Steve appearance.
+     *
+     * <p>All skin-related fields are reset and the {@code "textures"} property is
+     * removed from the GameProfile.  If the bot is in the world, observers see
+     * the change immediately.</p>
+     */
+    public void clearSkin() {
+        this.skinTextureValue = null;
+        this.skinSignature    = null;
+        this.skinSlimModel    = false;
+        this.capeTextureUrl   = null;
+        applySkinToProfile();
+        refreshTracking();
+    }
+
+    /** Returns {@code true} if a custom skin is currently installed. */
+    public boolean hasSkin() {
+        return skinTextureValue != null;
+    }
+
+    /**
+     * Returns the Base64-encoded textures JSON currently set on this bot's
+     * profile, or {@code null} if no custom skin is installed.
+     */
+    public String getSkinTextureValue() {
+        return skinTextureValue;
+    }
+
+    /**
+     * Returns the Mojang signature for the current skin property,
+     * or {@code null} if the skin is unsigned or none is installed.
+     */
+    public String getSkinSignature() {
+        return skinSignature;
+    }
+
+    /**
+     * Returns {@code true} if the current skin uses the slim-arm (Alex) model.
+     * Only meaningful when a skin was installed via {@link #setSkin}.
+     */
+    public boolean isSkinSlim() {
+        return skinSlimModel;
+    }
+
+    /**
+     * Returns the cape texture URL currently embedded in the skin, or {@code null}
+     * if no cape is set.  Only meaningful when a skin was installed via
+     * {@link #setSkin}.
+     */
+    public String getCapeTextureUrl() {
+        return capeTextureUrl;
+    }
+}
