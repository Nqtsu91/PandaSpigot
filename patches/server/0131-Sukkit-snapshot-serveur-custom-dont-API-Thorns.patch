+        Bukkit.getPluginManager().callEvent(new org.bukkit.event.entity.PotionRemovedEvent(entity, effect));
+    }
+
+    /**
+     * PotionAddedEvent
+     */
+    public static PotionAddedEvent callPotionAddedEvent(EntityLiving receiver, net.minecraft.server.MobEffect nmsEffect) {
