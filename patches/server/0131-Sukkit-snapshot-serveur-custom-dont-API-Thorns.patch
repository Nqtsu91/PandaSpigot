+/**
+ * A no-operation {@link NetworkManager} used by {@link EntityFakePlayer}.
+ *
+ * <p>Uses a Netty {@link EmbeddedChannel} so that all {@code channel != null}
+ * and {@code channel.isOpen()} guards in NetworkManager pass without creating
+ * a real socket.  All packet-sending paths are overridden to no-ops so the
+ * server never serializes a packet for a fake player.</p>
+ *
+ * <h3>Thread safety</h3>
+ * EmbeddedChannel is single-threaded by design (uses its own EventLoop), but
+ * we never actually write to it.  All overridden methods are no-ops, so there
+ * is no threading concern.
+ */
+public class FakeNetworkManager extends NetworkManager {
+
+    public FakeNetworkManager() {
+        super(EnumProtocolDirection.SERVERBOUND);
+        // EmbeddedChannel: fully functional Netty channel backed by in-memory
+        // buffers.  channel.isOpen() returns true until explicitly closed.
+        this.channel = new EmbeddedChannel();
+        this.l = new InetSocketAddress(InetAddress.getLoopbackAddress(), 0);
+        this.preparing = false;
+    }
+
+    // ─────────────────────────────────────────────────────────────────────────
+    // Packet dispatch — all suppressed
+    // ─────────────────────────────────────────────────────────────────────────
+
+    /**
+     * Called by {@link PlayerConnection#sendPacket}.  No-op for fake players.
+     */
+    @Override
+    public void handle(Packet packet) {
+        // No-op: there is no real client to receive this packet.
+    }
+
+    /**
+     * Called by the flush-consolidation path.  No-op for fake players.
+     */
+    @Override
+    public void a(Packet packet,
+                  GenericFutureListener<? extends Future<? super Void>> genericfuturelistener,
+                  GenericFutureListener<? extends Future<? super Void>>... agenericfuturelistener) {
+        // No-op: there is no real client to receive this packet.
+    }
+
+    /**
+     * Override the NetworkManager tick (called from ServerConnection.c()).
+     * We are NOT registered with ServerConnection, so this is never called;
+     * the override is here as a safety net.
+     */
+    @Override
+    public void a() {
+        // No-op: fake network manager is not in ServerConnection's manager list.
+    }
+}
