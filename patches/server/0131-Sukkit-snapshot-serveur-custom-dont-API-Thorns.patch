+package net.minecraft.server;
+
+/**
+ * A no-operation {@link PlayerConnection} used by {@link EntityFakePlayer}.
+ *
+ * <p>All methods that would interact with a real network connection or client
+ * are suppressed.  The tick method {@link #c()} is intentionally a no-op
+ * because fake players don't need keepAlive, chat throttle, or idle-kick
+ * processing.</p>
+ *
+ * <h3>CPU impact</h3>
+ * Since {@code sendPacket} is a no-op, the server never serializes packets for
+ * fake players.  {@code c()} is a no-op so the server doesn't waste time on
+ * keepAlive or idle logic.  The only overhead is from the entity tick itself.
+ */
+public class FakePlayerConnection extends PlayerConnection {
+
+    public FakePlayerConnection(MinecraftServer server,
+                                 FakeNetworkManager networkManager,
+                                 EntityFakePlayer fakePlayer) {
+        super(server, networkManager, fakePlayer);
+    }
+
+    // ─────────────────────────────────────────────────────────────────────────
+    // Packet sending — suppressed
+    // ─────────────────────────────────────────────────────────────────────────
+
+    /**
+     * All packets destined for the fake player are silently dropped.
+     * This is the primary cost-reduction point: no serialization, no I/O.
+     */
+    @Override
+    public void sendPacket(final Packet packet) {
+        // No-op: fake player has no real client.
+    }
+
+    // ─────────────────────────────────────────────────────────────────────────
+    // IUpdatePlayerListBox tick — suppressed
+    // ─────────────────────────────────────────────────────────────────────────
+
+    /**
+     * Suppressed: keepAlive packets, chat throttle, idle kick — all irrelevant
+     * for server-controlled entities.
+     */
+    @Override
+    public void c() {
+        // No-op.
+    }
+
+    // ─────────────────────────────────────────────────────────────────────────
+    // Disconnect — suppressed
+    // ─────────────────────────────────────────────────────────────────────────
+
+    /**
+     * Disconnect requests are silently ignored.  Fake players are removed via
+     * {@link org.bukkit.craftbukkit.fakeplayer.FakePlayerManager#remove}.
+     */
+    @Override
+    public void disconnect(IChatBaseComponent reason) {
+        // No-op: use FakePlayerManager.remove() instead.
+    }
+}
