Subject: [PATCH] Sukkit: snapshot serveur custom (dont API Thorns)
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Snapshot du working tree des ajouts Sukkit côté serveur : FakePlayer,
PlayerReceiveDamage/Potion/enchant hooks, et l'API Thorns
(EnchantmentThorns.b fire EntityThornsEvent via CraftEventFactory).

Co-Authored-By: Claude Opus 4.8 <noreply@anthropic.com>

diff --git a/src/main/java/net/minecraft/server/EnchantmentThorns.java b/src/main/java/net/minecraft/server/EnchantmentThorns.java
index 913e5e4451674b438e18fbb3aac13295202c23e1..b979620cee6776940a38897dc25cf7376f949472 100644
--- a/src/main/java/net/minecraft/server/EnchantmentThorns.java
+++ b/src/main/java/net/minecraft/server/EnchantmentThorns.java
@@ -29,14 +29,23 @@ public class EnchantmentThorns extends Enchantment {
         Random random = entityliving.bc();
         ItemStack itemstack = EnchantmentManager.a(Enchantment.THORNS, entityliving);
 
-        if (entity != null && a(i, random)) { // CraftBukkit
-            if (entity != null) {
-                entity.damageEntity(DamageSource.a(entityliving), (float) b(i, random));
+        if (entity != null) {
+            // Sukkit: expose thorns activation chance + reflected damage via a cancellable
+            // event. Defaults mirror vanilla (chance 0.15*level, damage b(i)), so unmodified
+            // behaviour is byte-for-byte identical for plugins that don't listen.
+            float chance = 0.15F * (float) i;
+            float damage = (float) b(i, random);
+            org.bukkit.event.entity.EntityThornsEvent event =
+                    org.bukkit.craftbukkit.event.CraftEventFactory.callEntityThornsEvent(entityliving, entity, i, chance, damage);
+
+            if (!event.isCancelled() && random.nextFloat() < event.getActivationChance()) {
+                entity.damageEntity(DamageSource.a(entityliving), event.getReflectedDamage());
                 entity.makeSound("damage.thorns", 0.5F, 1.0F);
-            }
-
-            if (itemstack != null) {
-                itemstack.damage(3, entityliving);
+                if (itemstack != null) {
+                    itemstack.damage(3, entityliving);
+                }
+            } else if (itemstack != null) {
+                itemstack.damage(1, entityliving);
             }
         } else if (itemstack != null) {
             itemstack.damage(1, entityliving);
diff --git a/src/main/java/net/minecraft/server/EntityFakePlayer.java b/src/main/java/net/minecraft/server/EntityFakePlayer.java
new file mode 100644
index 0000000000000000000000000000000000000000..a969ffdf4b74241d35fc54fa84f03b0ef117ee83
--- /dev/null
+++ b/src/main/java/net/minecraft/server/EntityFakePlayer.java
@@ -0,0 +1,1426 @@
+package net.minecraft.server;
+
+import com.mojang.authlib.GameProfile;
+import com.mojang.authlib.properties.Property;
+import java.nio.charset.StandardCharsets;
+import java.util.Base64;
+import java.util.UUID;
+
+/**
+ * A server-controlled {@link EntityPlayer} entity that acts as a lightweight
+ * NPC or combat bot.
+ *
+ * <h3>Design goals</h3>
+ * <ul>
+ *   <li><b>Lightweight</b>: {@code viewDistance = 0} (no chunk loading), no
+ *       packet serialization, no keepAlive, no stats I/O.</li>
+ *   <li><b>Correct combat</b>: takes knockback via the normal
+ *       {@link EntityLiving#damageEntity} path; respects {@code noDamageTicks};
+ *       issues vanilla-strength melee attacks.</li>
+ *   <li><b>No side effects</b>: death does not fire {@code PlayerDeathEvent},
+ *       no loot is dropped, no respawn screen appears.</li>
+ * </ul>
+ *
+ * <h3>Tick architecture</h3>
+ * The world calls {@link #t_()} every tick.  Our override chains:
+ * <ol>
+ *   <li>{@code super.t_()} — light EntityPlayer tick (invulnerableTicks,
+ *       noDamageTicks, container check, spectator check).</li>
+ *   <li>{@code super.l()} — full physics via {@code EntityHuman.t_()}:
+ *       gravity, velocity, potion effects, food, AI hooks.  All
+ *       {@code sendPacket()} calls inside are no-ops.</li>
+ *   <li>{@link #tickAI()} — our custom state machine.</li>
+ * </ol>
+ * {@link #l()} is overridden to a no-op because it is only invoked by
+ * {@link PlayerConnection} movement-packet handlers that we suppress.
+ *
+ * <h3>Thread safety</h3>
+ * All operations must occur on the server main thread.
+ */
+public class EntityFakePlayer extends EntityPlayer {
+
+    // ─────────────────────────────────────────────────────────────────────────
+    // AI state machine
+    // ─────────────────────────────────────────────────────────────────────────
+
+    /** Operating mode for this fake player. */
+    public enum Mode {
+        /**
+         * Static NPC — does not move or attack.
+         * Takes damage and knockback normally.
+         */
+        NPC,
+        /**
+         * Static display entity — immune to all entity-sourced damage and
+         * knockback (sword hits, arrows, explosions, etc.).
+         * Environmental damage (fall, fire, void) is unaffected.
+         */
+        NO_AI,
+        /** Combat bot — pursues and attacks the current {@link #combatTarget}. */
+        COMBAT
+    }
+
+    private Mode mode = Mode.NPC;
+    private EntityLiving combatTarget = null;
+
+    /** Ticks remaining before the next attack is allowed (vanilla: 20 ticks). */
+    private int attackCooldown = 0;
+
+    /**
+     * Ticks remaining during which AI motion is suppressed to let knockback
+     * play out.  Set by {@link #damageEntity} the moment real damage is
+     * registered — before {@link Entity#g} (the actual knockback impulse) is
+     * called by the attacker.  This makes the guard independent of entity-tick
+     * ordering (FakePlayer may tick before or after its attacker).
+     */
+    private int knockbackCooldown = 0;
+
+    /**
+     * Number of golden apples available to this bot.
+     * Decremented each time one is fully consumed.  0 means no healing available.
+     */
+    private int gappleCount = 0;
+
+    /**
+     * Countdown for the current eating animation, in ticks.
+     * Counts from {@link #EAT_DURATION_TICKS} down to 0.  0 = not eating.
+     */
+    private int eatTicks = 0;
+    /**
+     * Ticks remaining before the bot may eat another golden apple.
+     * Set to {@link #GAPPLE_COOLDOWN_TICKS} when an eat completes.
+     */
+    private int gappleCooldown = 0;
+
+    /**
+     * Whether this bot is allowed to place water to extinguish itself.
+     * Defaults to {@code true}.  Set to {@code false} for bots where the
+     * water-clutch mechanic is undesired (arenas without water, etc.).
+     */
+    private boolean waterEnabled = true;
+
+    // ── Water clutch ─────────────────────────────────────────────────────────
+
+    /**
+     * Current phase of the bucket-hold countdown.
+     * <ul>
+     *   <li>0 — bucket hold done (water may or may not be active, see {@link #waterPos})</li>
+     *   <li>{@link #WATER_START_PHASE} → {@link #WATER_PLACE_PHASE}+1 — holding bucket</li>
+     *   <li>{@link #WATER_PLACE_PHASE} — place water this tick, then → 0</li>
+     * </ul>
+     */
+    private int           waterPhase       = 0;
+    /**
+     * Ticks the placed water block will stay on the ground.
+     * Decremented each tick while {@link #waterPos} is non-null.
+     * Set to 1 (fire) or {@link #waterLavaStayTicks} (lava) at placement time.
+     */
+    private int           waterActiveTicks = 0;
+    /** Ticks until the next water clutch is allowed. */
+    private int           waterCooldown    = 0;
+    /** World position where the water source was placed, used for removal. */
+    private BlockPosition waterPos         = null;
+    /** Hand item active before the bucket was swapped in; restored after clutch. */
+    private ItemStack     savedHand        = null;
+
+    /** Walk speed in blocks per tick (vanilla walk ≈ 0.18). */
+    private static final double WALK_SPEED = 0.20;
+    /**
+     * Sprint speed in blocks per tick.
+     * Vanilla sprint equilibrium ≈ 0.28 b/t (attribute 0.1 × 1.3 × friction chain).
+     */
+    private static final double SPRINT_SPEED = 0.28;
+    /**
+     * Horizontal speed while swimming.
+     * Fluid drag (factor 0.8/tick) caps effective speed to ~50 % of ground;
+     * 0.10 keeps movement responsive without fighting the physics.
+     */
+    private static final double SWIM_SPEED = 0.10;
+    /**
+     * Upward velocity applied every tick while submerged.
+     *
+     * <p>Fluid physics in {@link Entity#t_()} apply per tick:
+     * {@code motY = motY × 0.8 − 0.02}.  At 0.20, the net ascent after damping
+     * is {@code 0.20 × 0.8 − 0.02 = 0.14 b/t}, which reliably lifts the bot
+     * to the surface without overshooting.</p>
+     */
+    private static final double SWIM_UP_SPEED = 0.20;
+    /**
+     * Vanilla jump initial upward velocity.
+     * Produces a peak height of ~1.25 blocks on flat ground.
+     */
+    private static final double JUMP_VELOCITY = 0.42;
+    /**
+     * Melee attack range squared (3.5 blocks → 12.25 blocks²).
+     *
+     * <p>3.5 blocks is the standard reach used on competitive 1.8 servers to
+     * compensate for client-side latency and gives the bot a natural feel.
+     * Vanilla client reach is 3 blocks but the server-side check is typically
+     * set slightly higher.</p>
+     */
+    private static final double ATTACK_RANGE_SQ = 12.25; // 3.5 blocks
+    /**
+     * Phantom swing range squared (7 blocks → 49 blocks²).
+     *
+     * <p>Between {@link #ATTACK_RANGE_SQ} and this value the bot performs arm-swing
+     * animations at the normal rate ({@link #ATTACK_COOLDOWN_TICKS}) without
+     * dealing damage.  Mimics a real player clicking while closing distance.</p>
+     */
+    private static final double PHANTOM_RANGE_SQ = 49.0; // 7 blocks
+    /**
+     * Ticks between arm-swing and damage attempts (4 ticks = 5 CPS / 0.2 s).
+     *
+     * <p>Damage is no longer gated on the target's {@code noDamageTicks}: the
+     * call is always forwarded to {@link EntityHuman#attack}, which delegates
+     * to {@link EntityLiving#damageEntity}.  That method's own invincibility
+     * check ({@code noDamageTicks > maxNoDamageTicks / 2}) blocks redundant
+     * hits automatically, so on vanilla servers effective hits land every
+     * ~10–12 ticks (≈ 2 hits/s).  On competitive servers where
+     * {@code maxNoDamageTicks} is reduced to 0 every swing deals damage,
+     * yielding the intended 5 CPS.</p>
+     */
+    private static final int ATTACK_COOLDOWN_TICKS = 4;
+    /**
+     * Ticks to hold AI motion after taking damage.
+     * Vanilla knockback decays to walk-speed in ~6 ticks on normal ground
+     * (friction factor 0.546 per tick).
+     */
+    private static final int KNOCKBACK_PRESERVE_TICKS = 6;
+    /**
+     * Health points below which the bot will eat a golden apple (default 14 HP = 7 hearts).
+     * Chosen high enough that Regeneration II has time to heal before death.
+     */
+    private static final float EAT_HP_THRESHOLD   = 14.0f;
+    /**
+     * Ticks required to finish eating one golden apple.
+     * Vanilla food items take 32 ticks (1.6 s).
+     */
+    private static final int   EAT_DURATION_TICKS = 32;
+    /**
+     * Ticks the bot must wait between consecutive golden apple eats (1.5 s = 30 ticks).
+     * Prevents back-to-back consumption when health dips below the threshold multiple
+     * times in quick succession.
+     */
+    private static final int   GAPPLE_COOLDOWN_TICKS = 30;
+    /**
+     * Index of the "using item / blocking" flag in {@link Entity}'s DataWatcher byte 0.
+     * Bit 4 (0x10) — causes clients to render the eating/blocking arm-raise animation.
+     */
+    private static final int   FLAG_USING_ITEM    = 4;
+
+    /**
+     * Ticks to hold the water bucket in hand before placing (0.3 s = 6 ticks).
+     * The client animation is visible for exactly this duration.
+     */
+    private static final int WATER_HOLD_TICKS  = 6;
+    /**
+     * Starting value of {@link #waterPhase} (the bucket-hold countdown).
+     * One tick is reserved for the actual placement step.
+     */
+    private static final int WATER_START_PHASE = WATER_HOLD_TICKS + 1; // 7
+    /**
+     * Value of {@link #waterPhase} at which the water source block is placed.
+     * This is the last decrement step before the phase returns to 0.
+     */
+    private static final int WATER_PLACE_PHASE = 1;
+
+    /**
+     * Per-bot cooldown between water clutches, in ticks.
+     * Default 100 ticks (5 s).  Adjustable via {@link #setWaterCooldownDuration(int)}.
+     */
+    private int waterCooldownDuration = 100;
+    /**
+     * Ticks the water block stays active when the bot's feet or head are in lava.
+     * Default 60 ticks (3 s) — enough to survive full submersion and extinguish.
+     * Adjustable via {@link #setWaterLavaStayTicks(int)}.
+     */
+    private int waterLavaStayTicks = 60;
+
+    // ─────────────────────────────────────────────────────────────────────────
+    // Per-clone customisation — skin & reach
+    // ─────────────────────────────────────────────────────────────────────────
+
+    /**
+     * Per-clone squared melee reach in blocks².
+     * Defaults to {@link #ATTACK_RANGE_SQ} (3.5 blocks).
+     * Changed via {@link #setAttackRange(double)}.
+     */
+    private double attackRangeSq = ATTACK_RANGE_SQ;
+
+    /**
+     * Base64-encoded textures JSON placed as the {@code "textures"} property
+     * in this bot's {@link GameProfile}.  {@code null} = no custom skin
+     * (clients fall back to the default Steve skin).
+     *
+     * <p>Build this value with {@link #setSkin(String, boolean, String)} or
+     * supply a pre-signed value from the Mojang API with
+     * {@link #setSkinRaw(String, String)}.</p>
+     */
+    private String skinTextureValue = null;
+
+    /**
+     * Mojang signature for {@link #skinTextureValue}, or {@code null} for an
+     * unsigned property.
+     *
+     * <p>Unsigned skins are accepted by most servers in offline/Bungeecord
+     * mode but may be refused by vanilla online-mode clients.</p>
+     */
+    private String skinSignature = null;
+
+    /**
+     * Whether the slim-arm (Alex) model is used when a custom skin is set.
+     * {@code false} = Steve (default 4-px arms), {@code true} = Alex (3-px).
+     * Has no effect when no custom skin is installed.
+     */
+    private boolean skinSlimModel = false;
+
+    /**
+     * Cape texture URL embedded in the textures JSON, or {@code null} for no
+     * cape.  Relevant only when {@link #skinTextureValue} is also set.
+     */
+    private String capeTextureUrl = null;
+
+    /**
+     * Horizontal impulse added per tick toward the target while the FakePlayer
+     * is airborne (W-tap simulation).
+     *
+     * <p>Vanilla air-control factor is 0.02 × sprint-speed ≈ 0.0056 b/t.  We use
+     * 20 % of {@link #SPRINT_SPEED} (= 0.056 b/t) — roughly 10× vanilla — so the
+     * FakePlayer visibly fights the arc without overriding it completely.  This
+     * reduces peak knockback drift from ~6 blocks to ~3–4 blocks, matching what a
+     * skilled player achieves with a W-tap.</p>
+     */
+    private static final double AIR_COUNTERFORCE = SPRINT_SPEED * 0.20;
+
+    // ─────────────────────────────────────────────────────────────────────────
+    // Construction
+    // ─────────────────────────────────────────────────────────────────────────
+
+    /**
+     * Creates a new EntityFakePlayer with the given number of golden apples.
+     *
+     * <p>The entity is NOT yet added to the world.  Call
+     * {@link WorldServer#addEntity(Entity)} after setting the initial position
+     * via {@link #setPositionRotation(double, double, double, float, float)}.</p>
+     *
+     * @param server      the MinecraftServer instance
+     * @param world       the target world
+     * @param name        display name (must be ≤16 chars for vanilla client compatibility)
+     * @param gappleCount initial number of golden apples available for self-healing
+     */
+    public EntityFakePlayer(MinecraftServer server, WorldServer world, String name, int gappleCount) {
+        super(server, world,
+              new GameProfile(UUID.randomUUID(), name),
+              new PlayerInteractManager(world));
+
+        this.gappleCount = Math.max(0, gappleCount);
+
+        // Disable chunk loading — view distance 0 means PlayerChunkMap never
+        // enqueues chunks for this player.
+        this.viewDistance = 0;
+
+        // Wire up the no-op network stack.
+        FakeNetworkManager fakeNet = new FakeNetworkManager();
+        this.playerConnection = new FakePlayerConnection(server, fakeNet, this);
+
+        // Skip the one-tick joining delay used by real players.
+        this.joining = false;
+
+        // Start with full invulnerability window suppressed so combat can begin
+        // immediately.  Plugins can restore this if desired.
+        this.invulnerableTicks = 0;
+
+        // Keep food at maximum so EntityHuman.t_() never auto-cancels sprint.
+        // exhaustionLevel = 0 prevents saturation drain; saturation = 20 gives a
+        // long buffer before foodLevel would start dropping.
+        this.getFoodData().foodLevel      = 20;
+        this.getFoodData().saturationLevel = 20.0f;
+        this.getFoodData().exhaustionLevel = 0.0f;
+
+        // Replace the default inventory with a no-pickup variant.
+        // EntityItem.d(EntityHuman) calls inventory.canHold() first; returning 0
+        // short-circuits the entire pickup path (no event, no transfer, no fly-to
+        // animation).  The golden apple shown in-hand during eating is managed
+        // directly via setItem() and is NOT subject to this restriction.
+        this.inventory = new PlayerInventory(this) {
+            @Override public int     canHold(ItemStack itemstack) { return 0;     }
+            @Override public boolean pickup (ItemStack itemstack)  { return false; }
+        };
+    }
+
+    /**
+     * Convenience constructor — creates a FakePlayer with no golden apples.
+     *
+     * @param server the MinecraftServer instance
+     * @param world  the target world
+     * @param name   display name (must be ≤16 chars for vanilla client compatibility)
+     */
+    public EntityFakePlayer(MinecraftServer server, WorldServer world, String name) {
+        this(server, world, name, 0);
+    }
+
+    // ─────────────────────────────────────────────────────────────────────────
+    // Entity tick
+    // ─────────────────────────────────────────────────────────────────────────
+
+    /**
+     * Main entity tick, called every game tick by {@link World#entityJoinedWorld}.
+     *
+     * <p>Executes three phases in order: the light EntityPlayer tick, the full
+     * EntityHuman physics tick, then our AI.</p>
+     */
+    @Override
+    public void t_() {
+        if (this.dead) return;
+
+        // Phase 1 — light EntityPlayer tick.
+        // Handles invulnerableTicks, noDamageTicks, container check, chunk queue
+        // (empty for viewDistance=0), removeQueue (empty since sendPacket is
+        // no-op so packets are dropped before being queued here).
+        super.t_();
+
+        // Phase 2 — full entity physics.
+        // super.l() calls EntityPlayer.l() → super.t_() = EntityHuman.t_()
+        // → EntityLiving.t_() → Entity.t_() for gravity, velocity, effects.
+        // Every sendPacket() inside is silently dropped by FakePlayerConnection.
+        super.l();
+
+        // Phase 3 — custom AI.
+        tickAI();
+    }
+
+    /**
+     * Overridden to a no-op.
+     *
+     * <p>{@code l()} is normally invoked by {@link PlayerConnection} position/
+     * flying packet handlers.  Since our {@link FakePlayerConnection} suppresses
+     * all incoming packets, this would never be called anyway.  Physics are
+     * driven instead through {@link #t_()} → {@code super.l()}.</p>
+     */
+    @Override
+    public void l() {
+        // No-op: physics are handled via super.l() in t_().
+    }
+
+    // ─────────────────────────────────────────────────────────────────────────
+    // AI implementation
+    // ─────────────────────────────────────────────────────────────────────────
+
+    private void tickAI() {
+        // NO_AI: fully static, no AI of any kind (water clutch also skipped).
+        if (mode == Mode.NO_AI) return;
+        if (mode != Mode.COMBAT || combatTarget == null) return;
+
+        // Drop target if it died.
+        if (combatTarget.dead || !combatTarget.isAlive()) {
+            combatTarget = null;
+            return;
+        }
+
+        // ── Water cooldown (always ticked, independent of state) ──────────────
+        if (waterCooldown > 0) --waterCooldown;
+
+        // ── Water clutch — highest priority (fire is immediately dangerous) ───
+        // Drive any active sequence: bucket-hold phase OR active water block.
+        if (waterPhase > 0 || waterPos != null) {
+            tickWater();
+            return;
+        }
+        // Start a clutch when on fire, cooldown elapsed, and ground allows it.
+        if (waterEnabled && this.fireTicks > 0 && waterCooldown == 0 && canPlaceWater()) {
+            if (eatTicks > 0) cancelEating(); // interrupt eating — fire is urgent
+            startWaterClutch();
+            return;
+        }
+
+        // ── Eating phase — takes priority over combat ──────────────────────────
+        if (gappleCooldown > 0) --gappleCooldown;
+
+        if (eatTicks > 0) {
+            tickEating();
+            return;
+        }
+        if (gappleCount > 0 && gappleCooldown == 0 && this.getHealth() < EAT_HP_THRESHOLD) {
+            // FakePlayerEatEvent — cancellable; no apple consumed if cancelled.
+            if (!this.world.isClientSide) {
+                org.bukkit.event.fakeplayer.FakePlayerEatEvent evt =
+                        new org.bukkit.event.fakeplayer.FakePlayerEatEvent(
+                                (org.bukkit.entity.Player) this.getBukkitEntity(),
+                                gappleCount - 1);
+                org.bukkit.Bukkit.getPluginManager().callEvent(evt);
+                if (evt.isCancelled()) return;
+            }
+            startEating();
+            return;
+        }
+
+        // ── Normal combat ─────────────────────────────────────────────────────
+        faceTarget();
+        moveTowardTarget();
+
+        if (attackCooldown > 0) {
+            --attackCooldown;
+        } else {
+            tryAttack();
+        }
+    }
+
+    /** Rotates yaw/pitch to face the current combat target. */
+    private void faceTarget() {
+        double dx = combatTarget.locX - this.locX;
+        double dy = (combatTarget.locY + combatTarget.length / 2.0)
+                    - (this.locY + this.getHeadHeight());
+        double dz = combatTarget.locZ - this.locZ;
+        double horizDist = Math.sqrt(dx * dx + dz * dz);
+
+        this.yaw = (float) (Math.atan2(-dx, dz) * (180.0 / Math.PI));
+        this.pitch = (float) -(Math.atan2(dy, horizDist) * (180.0 / Math.PI));
+    }
+
+    /**
+     * Applies motion toward the target each tick, handling three distinct movement
+     * modes: fluid swimming, airborne counterforce, and ground sprinting with
+     * automatic obstacle jumping.
+     *
+     * <h4>Knockback preservation — two complementary guards</h4>
+     * <ol>
+     *   <li><b>{@code velocityChanged}</b> — set by {@link Entity#g} in the same
+     *       game tick the hit lands (cleared by the entity tracker at tick end).
+     *       Guards against overwriting the impulse within the same tick.</li>
+     *   <li><b>{@link #knockbackCooldown}</b> — set in {@link #damageEntity} the
+     *       instant real damage is registered, <em>before</em> {@link Entity#g} is
+     *       called by the attacker.  Preserves residual velocity over subsequent
+     *       ticks regardless of tick ordering.</li>
+     * </ol>
+     *
+     * <h4>Fluid swimming</h4>
+     * When {@link #isInFluid()} is true, reduced horizontal speed is applied and
+     * a constant upward impulse ({@link #SWIM_UP_SPEED}) counteracts the fluid's
+     * downward pull so the bot rises naturally to the surface.
+     *
+     * <h4>Air counterforce (W-tap simulation)</h4>
+     * While airborne outside the knockback window, a small impulse
+     * ({@link #AIR_COUNTERFORCE}) is added toward the target each tick, reducing
+     * knockback drift from ~6 blocks to ~3–4 blocks.
+     *
+     * <h4>Obstacle jumping</h4>
+     * When on the ground and moving, {@link Entity#positionChanged} (set by
+     * {@link Entity#move} in the preceding physics step when the horizontal
+     * displacement was clipped by a solid block) signals that the entity hit a
+     * wall.  We respond with a vanilla jump impulse ({@link #JUMP_VELOCITY})
+     * to step over 1-block-high obstacles.
+     */
+    private void moveTowardTarget() {
+        // ── Knockback guard ────────────────────────────────────────────────────
+        if (this.velocityChanged || this.knockbackCooldown > 0) {
+            if (this.knockbackCooldown > 0) --this.knockbackCooldown;
+            return;
+        }
+
+        double dx          = combatTarget.locX - this.locX;
+        double dz          = combatTarget.locZ - this.locZ;
+        double horizDistSq = dx * dx + dz * dz;
+        boolean outOfRange = horizDistSq > attackRangeSq;
+
+        // ── Fluid movement (water / lava) ──────────────────────────────────────
+        // Apply reduced horizontal speed (fluid drag ≈ 0.8/tick) and a steady
+        // upward impulse so the bot swims toward the surface automatically.
+        // Sprint flag is cleared because it has no effect while submerged and
+        // would incorrectly drain food.
+        if (isInFluid()) {
+            this.setSprinting(false);
+            if (outOfRange && horizDistSq > 1e-4) {
+                double d = Math.sqrt(horizDistSq);
+                this.motX = (dx / d) * SWIM_SPEED;
+                this.motZ = (dz / d) * SWIM_SPEED;
+            } else {
+                this.motX = 0.0;
+                this.motZ = 0.0;
+            }
+            // Swim upward regardless of horizontal position — the fluid tick
+            // will dampen this to ~0.14 b/t net ascent per step.
+            this.motY = SWIM_UP_SPEED;
+            return;
+        }
+
+        // ── Air counterforce ───────────────────────────────────────────────────
+        // Vanilla air-control factor is ~0.02.  We add a small bias toward the
+        // target so the FakePlayer partially fights the knockback arc, as a
+        // skilled player presses W during airborne knockback.
+        if (!this.onGround) {
+            if (outOfRange && horizDistSq > 1e-4) {
+                double d = Math.sqrt(horizDistSq);
+                this.motX += (dx / d) * AIR_COUNTERFORCE;
+                this.motZ += (dz / d) * AIR_COUNTERFORCE;
+            }
+            return;
+        }
+
+        // ── Ground movement ────────────────────────────────────────────────────
+        // Keep sprinting through the attack range — only stop at physical
+        // collision distance (~1 block²) to avoid clipping into the target.
+        // Stopping at ATTACK_RANGE_SQ was causing the bot to halt mid-fight,
+        // making it miss hits when the target stepped back.
+        if (horizDistSq > 1.0) {
+            double d = Math.sqrt(horizDistSq);
+            this.setSprinting(true);
+            this.motX = (dx / d) * SPRINT_SPEED;
+            this.motZ = (dz / d) * SPRINT_SPEED;
+            // Obstacle jump: Entity.move() sets positionChanged when the
+            // entity's horizontal displacement was clipped by a solid block
+            // during the last physics step.  Jump to clear 1-block-high walls;
+            // motY guard prevents re-triggering while already ascending.
+            if (this.positionChanged && this.motY <= 0.0) {
+                this.motY = JUMP_VELOCITY;
+            }
+        } else {
+            this.setSprinting(false);
+            this.motX = 0.0;
+            this.motZ = 0.0;
+        }
+    }
+
+    /**
+     * Returns {@code true} if the entity's mid-body (at {@code locY + 0.5}) is
+     * inside a liquid block (water or lava).
+     *
+     * <p>The {@code + 0.5} offset avoids false positives when only the tip of
+     * a foot grazes the surface of a fluid source block.  It also correctly
+     * detects submersion at any depth because a 1-block fluid column covers the
+     * whole range {@code [Y, Y+1)}, and {@code locY + 0.5} always falls inside
+     * that range once the entity has sunk at least half a block.</p>
+     */
+    private boolean isInFluid() {
+        return this.world
+                   .getType(new BlockPosition(this.locX, this.locY + 0.5, this.locZ))
+                   .getBlock()
+                   .getMaterial()
+                   .isLiquid();
+    }
+
+    /**
+     * Handles attack logic based on distance to the target:
+     * <ul>
+     *   <li><b>≤ {@link #ATTACK_RANGE_SQ}</b> — real attack: arm swing + damage.</li>
+     *   <li><b>≤ {@link #PHANTOM_RANGE_SQ}</b> — phantom swing: arm animation only,
+     *       no damage.  Simulates a real player clicking while closing the gap.</li>
+     *   <li><b>beyond phantom range</b> — no action; cooldown is not consumed so
+     *       the bot attacks immediately once it closes in.</li>
+     * </ul>
+     *
+     * <p>{@code bw()} is {@link EntityLiving}'s swing-arm method: it guards against
+     * double-triggering, sets {@code ar=true}/{@code as=-1}, then sends
+     * {@link PacketPlayOutAnimation} (type 0) to all tracking players via the
+     * entity tracker.</p>
+     */
+    /**
+     * Handles attack logic based on distance to the target.
+     *
+     * <h4>Damage delegation</h4>
+     * Every swing in melee range forwards directly to {@link EntityHuman#attack}.
+     * {@link EntityLiving#damageEntity} contains its own invincibility check
+     * ({@code noDamageTicks > maxNoDamageTicks / 2}) that silently rejects
+     * redundant hits — we do not replicate that logic here.  This means:
+     * <ul>
+     *   <li>On servers with {@code maxNoDamageTicks = 0} (no hit-delay): every
+     *       swing deals damage (5 CPS at {@link #ATTACK_COOLDOWN_TICKS} = 4).</li>
+     *   <li>On vanilla servers ({@code maxNoDamageTicks = 20}): effective hits
+     *       land every ~10–12 ticks (≈ 2 hits/s), matching a fast-clicking
+     *       human player.</li>
+     * </ul>
+     *
+     * <h4>Zones</h4>
+     * <ul>
+     *   <li><b>≤ {@link #ATTACK_RANGE_SQ}</b> — swing + damage attempt
+     *       (fires {@link FakePlayerAttackEvent}).</li>
+     *   <li><b>≤ {@link #PHANTOM_RANGE_SQ}</b> — swing only, no event.</li>
+     *   <li><b>beyond phantom range</b> — nothing; cooldown not consumed.</li>
+     * </ul>
+     */
+    private void tryAttack() {
+        double dx     = combatTarget.locX - this.locX;
+        double dy     = combatTarget.locY - this.locY;
+        double dz     = combatTarget.locZ - this.locZ;
+        double distSq = dx * dx + dy * dy + dz * dz;
+
+        if (distSq <= attackRangeSq) {
+            this.bw();
+            attackCooldown = ATTACK_COOLDOWN_TICKS;
+
+            // Always attempt damage — EntityLiving.damageEntity() rejects the
+            // call internally when the target is still in its invincibility
+            // window, so no explicit noDamageTicks check is needed here.
+            if (!this.world.isClientSide) {
+                org.bukkit.entity.LivingEntity bTarget =
+                        (org.bukkit.entity.LivingEntity) combatTarget.getBukkitEntity();
+                org.bukkit.event.fakeplayer.FakePlayerAttackEvent evt =
+                        new org.bukkit.event.fakeplayer.FakePlayerAttackEvent(
+                                (org.bukkit.entity.Player) this.getBukkitEntity(), bTarget);
+                org.bukkit.Bukkit.getPluginManager().callEvent(evt);
+                if (evt.isCancelled()) return;
+            }
+
+            boolean wasAlive = !combatTarget.dead;
+            this.attack(combatTarget);
+
+            // Kill detection.
+            if (!this.world.isClientSide && wasAlive
+                    && (combatTarget.dead || !combatTarget.isAlive())) {
+                org.bukkit.entity.LivingEntity bVictim =
+                        (org.bukkit.entity.LivingEntity) combatTarget.getBukkitEntity();
+                org.bukkit.Bukkit.getPluginManager().callEvent(
+                        new org.bukkit.event.fakeplayer.FakePlayerKillEvent(
+                                (org.bukkit.entity.Player) this.getBukkitEntity(), bVictim));
+            }
+
+        } else if (distSq <= PHANTOM_RANGE_SQ) {
+            // Phantom swing — animation only, no event, no damage attempt.
+            this.bw();
+            attackCooldown = ATTACK_COOLDOWN_TICKS;
+        }
+        // Beyond phantom range: cooldown stays at 0 so the bot attacks immediately
+        // the instant the target enters melee distance.
+    }
+
+    // ─────────────────────────────────────────────────────────────────────────
+    // Water clutch — fire extinguish
+    // ─────────────────────────────────────────────────────────────────────────
+
+    /**
+     * Returns {@code true} when the bot can safely place a water source at its
+     * feet.
+     *
+     * <p>Two conditions are required:
+     * <ol>
+     *   <li>The bot is on the ground ({@link Entity#onGround}).</li>
+     *   <li>The block directly below the feet is not air (user requirement: a
+     *       solid surface must exist to "click on" with the bucket).</li>
+     * </ol>
+     * The block AT feet level must also be replaceable (air or similar) so the
+     * water source can actually be placed there.</p>
+     */
+    private boolean canPlaceWater() {
+        if (!this.onGround) return false;
+        int fx = MathHelper.floor(this.locX);
+        int fy = MathHelper.floor(this.locY);
+        int fz = MathHelper.floor(this.locZ);
+        // Block below (what the bot stands on) must not be air.
+        Material belowMat = this.world.getType(new BlockPosition(fx, fy - 1, fz))
+                                      .getBlock().getMaterial();
+        if (belowMat == Material.AIR) return false;
+        // Block at feet must accept water placement (replaceable = air, water, etc.)
+        Material footMat = this.world.getType(new BlockPosition(fx, fy, fz))
+                                     .getBlock().getMaterial();
+        return footMat.isReplaceable();
+    }
+
+    /**
+     * Begins the water-clutch sequence.
+     *
+     * <p>Sets {@link #waterPhase} to {@link #WATER_START_PHASE} and swaps the
+     * hand item to a water bucket so clients see the correct item during the hold
+     * animation.  The previous hand item is saved in {@link #savedHand} for
+     * restoration at sequence end.</p>
+     */
+    private void startWaterClutch() {
+        waterPhase = WATER_START_PHASE;
+        savedHand  = this.inventory.getItemInHand();
+        this.inventory.setItem(this.inventory.itemInHandIndex,
+                               new ItemStack(Items.WATER_BUCKET));
+    }
+
+    /**
+     * Drives the water-clutch sequence each tick.  Handles two sub-phases:
+     *
+     * <h4>Active-water sub-phase ({@link #waterPos} ≠ null)</h4>
+     * The source block is on the ground; {@link #waterActiveTicks} counts down.
+     * When it reaches 0 the block is removed (restored to air), the hand item
+     * is restored, and the per-bot cooldown ({@link #waterCooldownDuration}) is armed.
+     *
+     * <h4>Bucket-hold sub-phase ({@link #waterPhase} > 0)</h4>
+     * {@link #waterPhase} decrements each tick.  When it reaches
+     * {@link #WATER_PLACE_PHASE} the water source block is placed and
+     * {@link #waterActiveTicks} is set to:
+     * <ul>
+     *   <li><b>1 tick</b> — normal fire (removed next physics step, enough to extinguish)</li>
+     *   <li><b>{@link #waterLavaStayTicks}</b> — lava detected at feet or head
+     *       (bot needs several seconds of water contact to leave the lava pool)</li>
+     * </ul>
+     * Direct NMS block placement: {@code BlockPlaceEvent} / {@code BlockBreakEvent}
+     * are NOT fired by this code.
+     */
+    private void tickWater() {
+        // ── Active-water sub-phase ─────────────────────────────────────────────
+        if (waterPos != null) {
+            if (--waterActiveTicks <= 0) {
+                this.world.setTypeAndData(waterPos, Blocks.AIR.getBlockData(), 3);
+                waterPos = null;
+                this.inventory.setItem(this.inventory.itemInHandIndex, savedHand);
+                savedHand     = null;
+                waterCooldown = waterCooldownDuration;
+            }
+            return; // waterPhase is 0 here; always return
+        }
+
+        // ── Bucket-hold / placement sub-phase ─────────────────────────────────
+        if (waterPhase == WATER_PLACE_PHASE) {
+            waterPos = new BlockPosition(this.locX, this.locY, this.locZ);
+            this.world.setTypeAndData(waterPos, Blocks.WATER.getBlockData(), 3);
+            // Stay longer if in lava so the bot can fully exit the pool.
+            waterActiveTicks = isInLava() ? waterLavaStayTicks : 1;
+        }
+        --waterPhase;
+    }
+
+    /**
+     * Aborts an in-progress water clutch, cleaning up the placed water block
+     * (if any) and restoring the previous hand item.  Used when the bot dies,
+     * switches to a static mode, or {@link #setWaterEnabled(boolean)} is called
+     * with {@code false} mid-sequence.
+     */
+    private void cancelWater() {
+        if (waterPos != null) {
+            this.world.setTypeAndData(waterPos, Blocks.AIR.getBlockData(), 3);
+            waterPos = null;
+        }
+        this.inventory.setItem(this.inventory.itemInHandIndex, savedHand);
+        savedHand        = null;
+        waterPhase       = 0;
+        waterActiveTicks = 0;
+    }
+
+    /**
+     * Returns {@code true} if the bot's feet block or head block is lava
+     * (either flowing or stationary).
+     *
+     * <p>Checks two positions:
+     * <ul>
+     *   <li><b>Feet</b>: block at {@code (floor(locX), floor(locY), floor(locZ))}</li>
+     *   <li><b>Head</b>: block at {@code (floor(locX), floor(locY + 1.4), floor(locZ))}</li>
+     * </ul>
+     * Both flowing ({@code Blocks.FLOWING_LAVA}) and stationary
+     * ({@code Blocks.LAVA}) lava share {@link Material#LAVA}, so a single
+     * {@code getMaterial()} comparison covers both.</p>
+     */
+    private boolean isInLava() {
+        int fx = MathHelper.floor(this.locX);
+        int fz = MathHelper.floor(this.locZ);
+        Material feetMat = this.world
+                .getType(new BlockPosition(fx, MathHelper.floor(this.locY), fz))
+                .getBlock().getMaterial();
+        Material headMat = this.world
+                .getType(new BlockPosition(fx, MathHelper.floor(this.locY + 1.4), fz))
+                .getBlock().getMaterial();
+        return feetMat == Material.LAVA || headMat == Material.LAVA;
+    }
+
+    // ─────────────────────────────────────────────────────────────────────────
+    // Eating — golden apple consumption
+    // ─────────────────────────────────────────────────────────────────────────
+
+    /**
+     * Begins eating a golden apple.
+     *
+     * <ul>
+     *   <li>Halts movement and sprinting, <em>unless</em> an active knockback
+     *       window is detected ({@link #knockbackCooldown} &gt; 0): in that case
+     *       the velocity is preserved so the impulse plays out normally.  The
+     *       subsequent {@link #tickEating()} calls carry the same guard for the
+     *       remainder of the eating animation.</li>
+     *   <li>Sets the {@link #FLAG_USING_ITEM} flag in the DataWatcher so clients
+     *       render the "arm raised" eating animation.</li>
+     *   <li>Places a {@link Items#GOLDEN_APPLE} in the held slot so clients
+     *       show the correct item during the eating pose.</li>
+     * </ul>
+     */
+    private void startEating() {
+        eatTicks = EAT_DURATION_TICKS;
+        this.setSprinting(false);
+        // If a knockback impulse was just applied (damageEntity set knockbackCooldown
+        // before calling Entity.g() on the attacker side), preserve the velocity so
+        // the knockback plays out.  tickEating() carries the same guard for the
+        // remaining ticks of the animation.
+        if (this.knockbackCooldown == 0) {
+            this.motX = 0.0;
+            this.motZ = 0.0;
+        }
+        // Arm-raise / eating animation visible to spectating players.
+        this.b(FLAG_USING_ITEM, true);
+        // Place apple in hand so clients render the food item during the pose.
+        this.inventory.setItem(this.inventory.itemInHandIndex,
+                               new ItemStack(Items.GOLDEN_APPLE));
+    }
+
+    /**
+     * Called each tick while the bot is eating.
+     *
+     * <p>Keeps the bot stationary and facing the target, but respects any
+     * active knockback window so received knockback plays out normally.
+     * Calls {@link #finishEating()} when the countdown reaches zero.</p>
+     */
+    private void tickEating() {
+        faceTarget();
+        this.setSprinting(false);
+
+        // Only zero velocity when no knockback is active — mirrors the guard
+        // in moveTowardTarget() so eating doesn't silently absorb knockback.
+        if (this.velocityChanged || this.knockbackCooldown > 0) {
+            if (this.knockbackCooldown > 0) --this.knockbackCooldown;
+        } else {
+            this.motX = 0.0;
+            this.motZ = 0.0;
+        }
+
+        if (--eatTicks <= 0) {
+            finishEating();
+        }
+    }
+
+    /**
+     * Completes the eating animation and applies vanilla golden-apple effects:
+     * <ul>
+     *   <li>Regeneration II for 5 seconds (100 ticks)</li>
+     *   <li>Absorption I for 2 minutes (2 400 ticks)</li>
+     *   <li>Food level / saturation restored (4 hunger + 9.6 saturation)</li>
+     * </ul>
+     * The golden apple is removed from the hand slot and the DataWatcher
+     * eating flag is cleared.
+     */
+    private void finishEating() {
+        --gappleCount;
+        gappleCooldown = GAPPLE_COOLDOWN_TICKS;
+        // Clear animation state.
+        this.b(FLAG_USING_ITEM, false);
+        this.inventory.setItem(this.inventory.itemInHandIndex, null);
+        // Potion effects — vanilla golden apple (1.8):
+        //   Regeneration II  (amplifier 1) for 100 ticks  (5 s)
+        //   Absorption I     (amplifier 0) for 2400 ticks (2 min)
+        this.addEffect(new MobEffect(MobEffectList.REGENERATION.id, 100,  1, false, true));
+        this.addEffect(new MobEffect(MobEffectList.ABSORBTION.id,   2400, 0, false, true));
+        // Restore food stats as if the item was eaten normally.
+        FoodMetaData food = this.getFoodData();
+        food.foodLevel      = Math.min(20, food.foodLevel + 4);
+        food.saturationLevel = Math.min(20.0f, food.saturationLevel + 9.6f);
+    }
+
+    /**
+     * Cancels an in-progress eating sequence without consuming a golden apple
+     * or applying any effects.  Used when the bot switches to NPC mode or dies.
+     */
+    private void cancelEating() {
+        eatTicks = 0;
+        this.b(FLAG_USING_ITEM, false);
+        this.inventory.setItem(this.inventory.itemInHandIndex, null);
+    }
+
+    // ─────────────────────────────────────────────────────────────────────────
+    // Damage — knockback cooldown
+    // ─────────────────────────────────────────────────────────────────────────
+
+    /**
+     * Intercepts successful damage to arm the knockback-preservation cooldown.
+     *
+     * <p>In {@link EntityHuman#attack}, the call order is:
+     * <ol>
+     *   <li>{@code target.damageEntity(…)} — damage applied, returns {@code true}</li>
+     *   <li>{@link Entity#g(double, double)} — knockback impulse applied on target</li>
+     * </ol>
+     * By setting {@link #knockbackCooldown} here — between steps 1 and 2 — we
+     * guarantee that {@link #moveTowardTarget()} will not override the impulse
+     * for the next {@link #KNOCKBACK_PRESERVE_TICKS} ticks, regardless of whether
+     * the FakePlayer ticks before or after its attacker in the same game tick.</p>
+     */
+    @Override
+    public boolean damageEntity(DamageSource damageSource, float damage) {
+        // NO_AI: immune to all entity-sourced damage (melee, arrows, explosions, ...).
+        // Environmental sources (fall, fire, void — getEntity() == null) pass through.
+        if (mode == Mode.NO_AI && damageSource.getEntity() != null) {
+            return false;
+        }
+
+        // FakePlayerDamagedEvent — fires before the damage pipeline.
+        // Cancelling skips all damage and prevents knockback.
+        if (!this.world.isClientSide) {
+            org.bukkit.entity.Entity bAttacker = (damageSource.getEntity() != null)
+                    ? damageSource.getEntity().getBukkitEntity()
+                    : null;
+            org.bukkit.event.fakeplayer.FakePlayerDamagedEvent evt =
+                    new org.bukkit.event.fakeplayer.FakePlayerDamagedEvent(
+                            (org.bukkit.entity.Player) this.getBukkitEntity(),
+                            damage, bAttacker);
+            org.bukkit.Bukkit.getPluginManager().callEvent(evt);
+            if (evt.isCancelled()) return false;
+            damage = evt.getDamage();
+        }
+
+        boolean tookDamage = super.damageEntity(damageSource, damage);
+        if (tookDamage) {
+            this.knockbackCooldown = KNOCKBACK_PRESERVE_TICKS;
+        }
+        return tookDamage;
+    }
+
+    /**
+     * Overrides the 3-argument knockback impulse to be a no-op in
+     * {@link Mode#NO_AI}.
+     *
+     * <p>This covers knockback from explosions, projectiles, and any other
+     * source that calls {@link Entity#g(double, double, double)} directly
+     * without going through {@link #damageEntity}.</p>
+     */
+    @Override
+    public void g(double d0, double d1, double d2) {
+        if (mode != Mode.NO_AI) {
+            super.g(d0, d1, d2);
+        }
+    }
+
+    // ─────────────────────────────────────────────────────────────────────────
+    // Death — no events, no loot
+    // ─────────────────────────────────────────────────────────────────────────
+
+    /**
+     * Marks the entity dead and removes it from {@code world.players}.
+     *
+     * <p>We bypass {@link EntityPlayer#die(DamageSource)} to avoid firing
+     * {@code PlayerDeathEvent}, broadcasting a death message, or triggering
+     * the respawn screen.  No items are dropped.</p>
+     *
+     * <p>The entity tracker will receive the removal signal from the world's
+     * entity tick loop, which calls {@link World#b(Entity)} (→
+     * {@code tracker.untrackEntity()}) once {@code dead == true} is detected.</p>
+     */
+    @Override
+    public void die(DamageSource damageSource) {
+        if (this.dead) return;
+
+        // FakePlayerDeathEvent — cancellable; plugins can revive the bot here.
+        if (!this.world.isClientSide) {
+            org.bukkit.entity.Entity bKiller = (damageSource.getEntity() != null)
+                    ? damageSource.getEntity().getBukkitEntity()
+                    : null;
+            org.bukkit.event.fakeplayer.FakePlayerDeathEvent evt =
+                    new org.bukkit.event.fakeplayer.FakePlayerDeathEvent(
+                            (org.bukkit.entity.Player) this.getBukkitEntity(), bKiller);
+            org.bukkit.Bukkit.getPluginManager().callEvent(evt);
+            if (evt.isCancelled()) return;
+        }
+
+        // Cancel any in-progress sequences so the DataWatcher flag, hand item,
+        // and placed water block are all cleaned up before entity removal.
+        if (waterPhase > 0) cancelWater();
+        if (eatTicks  > 0) cancelEating();
+        // Broadcast the death-fall animation (EntityStatus 3) BEFORE marking dead.
+        // After dead=true the world tick will call untrackEntity() next tick, so
+        // the entity is still fully tracked here and clients will receive the packet.
+        if (this.world instanceof WorldServer) {
+            ((WorldServer) this.world).broadcastEntityEffect(this, (byte) 3);
+        }
+        // Mark dead without any of the EntityPlayer.die() side-effects.
+        // aP is EntityLiving's internal death flag (set at EntityLiving.die() line 874).
+        // Some animation/packet paths check aP rather than dead, so set it here too.
+        this.aP = true;
+        this.dead = true;
+        // Remove from world.players immediately so mob spawn logic and
+        // findNearbyPlayer() don't reference a dead entity.
+        this.world.players.remove(this);
+        this.world.everyoneSleeping();
+    }
+
+    /**
+     * No-parameter die (called by {@link World#kill} and internal paths).
+     * Delegates to {@link #die(DamageSource)} with a generic cause.
+     */
+    @Override
+    public void die() {
+        die(DamageSource.GENERIC);
+    }
+
+    // ─────────────────────────────────────────────────────────────────────────
+    // Stats — no-op for performance
+    // ─────────────────────────────────────────────────────────────────────────
+
+    /**
+     * Intercepts all potion-effect additions to fire {@link FakePlayerEffectEvent}.
+     * Cancelling the event prevents the effect from being applied.
+     */
+    @Override
+    public void addEffect(MobEffect mobeffect) {
+        if (!this.world.isClientSide) {
+            org.bukkit.potion.PotionEffectType pet =
+                    org.bukkit.potion.PotionEffectType.getById(mobeffect.getEffectId());
+            if (pet != null) {
+                org.bukkit.potion.PotionEffect bEffect = new org.bukkit.potion.PotionEffect(
+                        pet, mobeffect.getDuration(), mobeffect.getAmplifier(),
+                        mobeffect.isAmbient(), true);
+                org.bukkit.event.fakeplayer.FakePlayerEffectEvent evt =
+                        new org.bukkit.event.fakeplayer.FakePlayerEffectEvent(
+                                (org.bukkit.entity.Player) this.getBukkitEntity(), bEffect);
+                org.bukkit.Bukkit.getPluginManager().callEvent(evt);
+                if (evt.isCancelled()) return;
+            }
+        }
+        super.addEffect(mobeffect);
+    }
