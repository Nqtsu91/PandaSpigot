+        this.enchantmentBonus   = enchantmentBonus;
+        this.critical           = critical;
+        this.criticalMultiplier = criticalMultiplier;
+        this.knockbackLevel     = knockbackLevel;
+    }
+
+    public float getRawBaseDamage()      { return rawBaseDamage; }
+    public float getEnchantmentBonus()   { return enchantmentBonus; }
+    public boolean isCritical()          { return critical; }
+    public float getCriticalMultiplier() { return criticalMultiplier; }
+    public int getKnockbackLevel()       { return knockbackLevel; }
+}
