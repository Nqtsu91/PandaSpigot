index 0000000000000000000000000000000000000000..5cc782895ef0eaf3a97fdba59ca4bfec2b97f441
--- /dev/null
+++ b/src/main/java/org/bukkit/craftbukkit/fakeplayer/FakePlayerManager.java
@@ -0,0 +1,541 @@
+package org.bukkit.craftbukkit.fakeplayer;
+
+import java.util.Collections;
+import java.util.Map;
+import java.util.UUID;
+import java.util.concurrent.ConcurrentHashMap;
+import net.minecraft.server.EntityFakePlayer;
+import net.minecraft.server.EntityLiving;
+import net.minecraft.server.MinecraftServer;
+import net.minecraft.server.WorldServer;
+import org.bukkit.Bukkit;
+import org.bukkit.Location;
+import org.bukkit.craftbukkit.CraftServer;
+import org.bukkit.craftbukkit.CraftWorld;
+import org.bukkit.craftbukkit.entity.CraftEntity;
+import org.bukkit.craftbukkit.entity.CraftPlayer;
+import org.bukkit.entity.Entity;
+import org.bukkit.entity.LivingEntity;
+import org.bukkit.entity.Player;
+import org.spigotmc.AsyncCatcher;
+
+/**
+ * Factory and lifecycle manager for {@link EntityFakePlayer} instances.
+ *
+ * <p>Fake players are server-controlled {@code EntityPlayer} entities that
+ * appear as player skins to clients.  They can operate in two modes:</p>
+ * <ul>
+ *   <li>{@link Mode#NPC} — static entity, does not move or attack.</li>
+ *   <li>{@link Mode#COMBAT} — pursues and melee-attacks a target entity.</li>
+ * </ul>
+ *
+ * <h3>Usage (plugin side)</h3>
+ * <pre>{@code
+ * import org.bukkit.craftbukkit.fakeplayer.FakePlayerManager;
+ * import org.bukkit.craftbukkit.fakeplayer.FakePlayerManager.Mode;
+ *
+ * // Spawn an NPC at the given location
+ * Player npc = FakePlayerManager.spawn(location, "Dummy");
+ *
+ * // Make it attack a real player
+ * FakePlayerManager.setTarget(npc, realPlayer);
+ *
+ * // Or change mode directly
+ * FakePlayerManager.setMode(npc, Mode.COMBAT);
+ *
+ * // Remove when done
+ * FakePlayerManager.remove(npc);
+ * }</pre>
+ *
+ * <h3>Thread safety</h3>
+ * All public methods enforce main-thread execution via
+ * {@link AsyncCatcher#catchOp(String)}.  The internal registry is a
+ * {@link ConcurrentHashMap} for safe iteration from other threads.
+ */
+public final class FakePlayerManager {
+
+    private FakePlayerManager() {}
+
+    /** Operating mode for fake players. */
+    public enum Mode {
+        /** Static — entity does not move or attack; takes damage normally. */
+        NPC,
+        /**
+         * Fully static display entity — immune to all entity-sourced damage
+         * (melee, arrows, explosions) and knockback.  Environmental damage
+         * (fall, fire, void) is unaffected.
+         */
+        NO_AI,
+        /** Combat bot — pursues and attacks the assigned target. */
+        COMBAT
+    }
+
+    // ─────────────────────────────────────────────────────────────────────────
+    // Internal registry
+    // ─────────────────────────────────────────────────────────────────────────
+
+    /**
+     * UUID → EntityFakePlayer map.
+     * Allows O(1) lookup, safe concurrent read from async plugins.
+     */
+    private static final Map<UUID, EntityFakePlayer> REGISTRY =
+            new ConcurrentHashMap<>();
+
+    // ─────────────────────────────────────────────────────────────────────────
+    // Lifecycle
+    // ─────────────────────────────────────────────────────────────────────────
+
+    /**
+     * Spawns a fake player at the given location in NPC mode with a preset
+     * number of golden apples for autonomous self-healing.
+     *
+     * <p>The entity is immediately visible to nearby real players.  Its
+     * {@link Mode} defaults to {@link Mode#NPC}.</p>
+     *
+     * @param location    spawn location (must be in a loaded chunk)
+     * @param name        display name shown in the tab list (max 16 chars)
+     * @param gappleCount initial number of golden apples (≥ 0)
+     * @return the Bukkit {@link Player} handle wrapping the fake entity
+     * @throws IllegalStateException if the chunk at location is not loaded
+     */
+    public static Player spawn(Location location, String name, int gappleCount) {
+        AsyncCatcher.catchOp("FakePlayerManager.spawn");
+
+        WorldServer worldServer = ((CraftWorld) location.getWorld()).getHandle();
+        MinecraftServer minecraftServer = ((CraftServer) Bukkit.getServer()).getServer();
+
+        EntityFakePlayer entity = new EntityFakePlayer(minecraftServer, worldServer, name,
+                                                       Math.max(0, gappleCount));
+        entity.setPositionRotation(
+                location.getX(), location.getY(), location.getZ(),
+                location.getYaw(), location.getPitch());
+
+        // FakePlayerSpawnEvent — cancellable; return null if a plugin vetoes.
+        org.bukkit.event.fakeplayer.FakePlayerSpawnEvent spawnEvent =
+                new org.bukkit.event.fakeplayer.FakePlayerSpawnEvent(
+                        (Player) entity.getBukkitEntity(), location);
+        Bukkit.getPluginManager().callEvent(spawnEvent);
+        if (spawnEvent.isCancelled()) return null;
+
+        boolean added = worldServer.addEntity(entity);
+        if (!added) {
+            throw new IllegalStateException(
+                    "Could not add EntityFakePlayer to world at " + location
+                    + " — is the chunk loaded?");
+        }
+
+        REGISTRY.put(entity.getUniqueID(), entity);
+        return (Player) entity.getBukkitEntity();
+    }
+
+    /**
+     * Spawns a fake player with no golden apples (convenience overload).
+     *
+     * @param location spawn location (must be in a loaded chunk)
+     * @param name     display name shown in the tab list (max 16 chars)
+     * @return the Bukkit {@link Player} handle wrapping the fake entity
+     */
+    public static Player spawn(Location location, String name) {
+        return spawn(location, name, 0);
+    }
+
+    /**
+     * Removes (despawns) a fake player from the world.
+     *
+     * <p>The entity is cleanly removed via {@link net.minecraft.server.World#kill},
+     * which unregisters it from the entity tracker (sending a removal packet to
+     * nearby clients) and removes it from {@code world.players}.</p>
+     *
+     * @param fakePlayer the player handle returned by {@link #spawn}
+     * @throws IllegalArgumentException if the entity is not a registered fake player
+     */
+    public static void remove(Player fakePlayer) {
+        AsyncCatcher.catchOp("FakePlayerManager.remove");
+
+        EntityFakePlayer entity = getNmsEntity(fakePlayer);
+        REGISTRY.remove(entity.getUniqueID());
+        entity.world.kill(entity);
+    }
+
+    // ─────────────────────────────────────────────────────────────────────────
+    // Mode & target control
+    // ─────────────────────────────────────────────────────────────────────────
+
+    /**
+     * Changes the operating mode of a fake player.
+     *
+     * @param fakePlayer the fake player handle
+     * @param mode       the desired mode
+     */
+    public static void setMode(Player fakePlayer, Mode mode) {
+        AsyncCatcher.catchOp("FakePlayerManager.setMode");
+        getNmsEntity(fakePlayer).setFakeMode(toNmsMode(mode));
+    }
+
+    /** Returns the current mode of a fake player. */
+    public static Mode getMode(Player fakePlayer) {
+        AsyncCatcher.catchOp("FakePlayerManager.getMode");
+        return fromNmsMode(getNmsEntity(fakePlayer).getFakeMode());
+    }
+
+    /**
+     * Assigns a combat target to a fake player and switches it to
+     * {@link Mode#COMBAT}.  Pass {@code null} to clear the target.
+     *
+     * @param fakePlayer the fake player handle
+     * @param target     entity to attack, or {@code null} to stop attacking
+     */
+    public static void setTarget(Player fakePlayer, LivingEntity target) {
+        AsyncCatcher.catchOp("FakePlayerManager.setTarget");
+        EntityLiving nmsTarget = (target != null)
+                ? (EntityLiving) ((CraftEntity) target).getHandle()
+                : null;
+        getNmsEntity(fakePlayer).setCombatTarget(nmsTarget);
+    }
+
+    /** Returns the current combat target, or {@code null} if none. */
+    public static LivingEntity getTarget(Player fakePlayer) {
+        AsyncCatcher.catchOp("FakePlayerManager.getTarget");
+        EntityLiving nms = getNmsEntity(fakePlayer).getCombatTarget();
