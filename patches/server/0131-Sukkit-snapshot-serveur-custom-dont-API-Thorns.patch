+    private static EntityFakePlayer getNmsEntity(Player player) {
+        UUID uuid = player.getUniqueId();
+        EntityFakePlayer entity = REGISTRY.get(uuid);
+        if (entity == null) {
+            throw new IllegalArgumentException(
+                    "Entity " + uuid + " is not a registered FakePlayer");
+        }
+        return entity;
+    }
