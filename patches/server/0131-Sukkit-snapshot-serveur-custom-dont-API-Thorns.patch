+    /**
+     * PlayerReceiveDamageEvent
+     */
+    public static PlayerReceiveDamageEvent callPlayerReceiveDamageEvent(
+            EntityPlayer victim,
+            DamageSource source,
+            float rawDamage,
+            float hardHatModifier,
+            float blockingModifier,
+            float armorModifier,
+            float resistanceModifier,
+            float magicModifier,
+            float absorptionModifier) {
+
+        org.bukkit.entity.Player player = victim.getBukkitEntity();
+        org.bukkit.entity.Entity sourceEntity = (source.getEntity() != null)
+                ? source.getEntity().getBukkitEntity() : null;
+
+        // Reductions are stored as negative deltas in NMS; expose as positive amounts
+        float hardHat   = Math.max(0, -hardHatModifier);
+        float blocking  = Math.max(0, -blockingModifier);
+        float armor     = Math.max(0, -armorModifier);
+        float resistance = Math.max(0, -resistanceModifier);
+        float magic     = Math.max(0, -magicModifier);
+        float absorption = Math.max(0, -absorptionModifier);
+
+        boolean fromPlayer = source instanceof net.minecraft.server.PlayerAttackDamageSource;
+        net.minecraft.server.PlayerAttackDamageSource playerSrc =
+                fromPlayer ? (net.minecraft.server.PlayerAttackDamageSource) source : null;
+
+        // Build a lazy supplier for hit location — captured entities are NMS-safe, computation deferred
+        final net.minecraft.server.EntityPlayer nmsVictim = victim;
+        final net.minecraft.server.DamageSource capturedSource = source;
+        java.util.function.Supplier<PlayerReceiveDamageEvent.HitLocation> hitLocSupplier = () -> {
+            double hitY;
+            double victimFeetY  = nmsVictim.locY;
+            double victimHeight = nmsVictim.length; // 1.8 standing, 1.65 crouching
+
+            // ---- Arrow: use the projectile's exact impact position ----
+            if (capturedSource instanceof net.minecraft.server.EntityDamageSourceIndirect) {
+                net.minecraft.server.Entity projectile =
+                        ((net.minecraft.server.EntityDamageSourceIndirect) capturedSource).getProximateDamageSource();
+                if (projectile instanceof net.minecraft.server.EntityArrow) {
+                    hitY = projectile.locY;
+                } else {
+                    // Other projectile (fireball, snowball…): centre of the projectile
+                    hitY = (projectile != null)
+                            ? projectile.locY + projectile.length / 2.0
+                            : -1;
+                }
+            }
+            // ---- Melee: ray from attacker's eyes along their look direction ----
+            // The attacker's pitch encodes exactly where on the target they aimed:
+            //   hitY = eyeY − sin(pitch) × horizDist
+            // (pitch positive = looking down in MC → sin positive → hitY below eye)
+            //
+            // Examples (attacker & victim at same Y, horizDist ≈ 2 blocks):
+            //   pitch =   0° → hitY = eyeY (1.62)        → fraction 0.90 → HEAD
+            //   pitch =  15° → hitY = 1.62−0.52 = 1.10  → fraction 0.61 → TORSO
+            //   pitch =  30° → hitY = 1.62−1.00 = 0.62  → fraction 0.34 → LEGS
+            //   pitch = −15° (jumping over) → hitY = 2.14 → clamped → HEAD
+            else {
+                net.minecraft.server.Entity nmsAttacker = capturedSource.getEntity();
+                if (nmsAttacker == null) {
+                    return PlayerReceiveDamageEvent.HitLocation.UNKNOWN;
+                }
+                double eyeY    = nmsAttacker.locY + nmsAttacker.getHeadHeight();
+                double dxA     = nmsVictim.locX - nmsAttacker.locX;
+                double dzA     = nmsVictim.locZ - nmsAttacker.locZ;
+                double hDist   = Math.sqrt(dxA * dxA + dzA * dzA);
+                if (hDist < 0.01) {
+                    // Same position (edge case) — aim at victim's centre
+                    hitY = victimFeetY + victimHeight * 0.5;
+                } else {
+                    double pitchRad = nmsAttacker.pitch * Math.PI / 180.0;
+                    hitY = eyeY - Math.sin(pitchRad) * hDist;
+                }
+            }
+
+            if (hitY < 0) return PlayerReceiveDamageEvent.HitLocation.UNKNOWN;
+
+            // Map to body part using victim-height-relative thresholds.
+            // HEAD  ≥ 78 %  (neck/chin: ~1.4 / 1.8 = 77.8 %)
+            // TORSO ≥ 39 %  (waist:     ~0.7 / 1.8)
+            // LEGS  ≥ 11 %  (shins:     ~0.2 / 1.8)
+            // FEET  <  11 %
+            double relHit  = Math.max(0.0, Math.min(victimHeight, hitY - victimFeetY));
+            double fraction = relHit / victimHeight;
+            if (fraction >= 0.78)  return PlayerReceiveDamageEvent.HitLocation.HEAD;
+            if (fraction >= 0.389) return PlayerReceiveDamageEvent.HitLocation.TORSO;
+            if (fraction >= 0.111) return PlayerReceiveDamageEvent.HitLocation.LEGS;
+            return PlayerReceiveDamageEvent.HitLocation.FEET;
+        };
+
+        PlayerReceiveDamageEvent event = new PlayerReceiveDamageEvent(
+                player,
+                sourceEntity,
+                rawDamage,
+                hardHat, blocking, armor, resistance, magic, absorption,
+                fromPlayer,
+                fromPlayer ? playerSrc.getRawBaseDamage()        : 0f,
+                fromPlayer ? playerSrc.getEnchantmentBonus()     : 0f,
+                fromPlayer && playerSrc.isCritical(),
+                fromPlayer ? playerSrc.getCriticalMultiplier()   : 1.5f,
+                fromPlayer ? playerSrc.getKnockbackLevel()       : 0,
+                hitLocSupplier
+        );
+
+        Bukkit.getPluginManager().callEvent(event);
+        return event;
+    }
+
+    /**
+     * EntityThornsEvent — fired from {@link net.minecraft.server.EnchantmentThorns} before
+     * the reflected damage is rolled/applied. Neutral to vanilla when unmodified.
+     */
+    public static org.bukkit.event.entity.EntityThornsEvent callEntityThornsEvent(
+            EntityLiving wearer, net.minecraft.server.Entity attacker, int level,
+            float activationChance, float reflectedDamage) {
+        org.bukkit.entity.LivingEntity defender = (org.bukkit.entity.LivingEntity) wearer.getBukkitEntity();
+        org.bukkit.entity.Entity attackerBukkit = attacker != null ? attacker.getBukkitEntity() : null;
+        org.bukkit.event.entity.EntityThornsEvent event = new org.bukkit.event.entity.EntityThornsEvent(
+                defender, attackerBukkit, level, activationChance, reflectedDamage);
+        Bukkit.getPluginManager().callEvent(event);
+        return event;
+    }
+
