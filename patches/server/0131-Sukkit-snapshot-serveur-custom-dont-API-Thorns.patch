+        org.bukkit.entity.Entity source = nmsSource != null ? nmsSource.getBukkitEntity() : null;
+
+        org.bukkit.potion.PotionEffectType type = org.bukkit.potion.PotionEffectType.getById(nmsEffect.getEffectId());
+        org.bukkit.potion.PotionEffect effect = new org.bukkit.potion.PotionEffect(
+                type,
+                nmsEffect.getDuration(),
+                nmsEffect.getAmplifier(),
+                nmsEffect.isAmbient(),
+                nmsEffect.isShowParticles()
