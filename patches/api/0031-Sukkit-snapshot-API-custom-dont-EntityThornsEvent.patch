--- /dev/null
+++ b/src/main/java/org/bukkit/event/entity/PotionAddedEvent.java
@@ -0,0 +1,75 @@
+package org.bukkit.event.entity;
+
+import org.bukkit.entity.Entity;
+import org.bukkit.entity.LivingEntity;
+import org.bukkit.event.Cancellable;
+import org.bukkit.event.HandlerList;
+import org.bukkit.potion.PotionEffect;
+
+/**
+ * Called when a potion effect is about to be added to a living entity.
+ * <p>
+ * Cancelling this event prevents the effect from being applied.
+ */
+public class PotionAddedEvent extends EntityEvent implements Cancellable {
+
+    private static final HandlerList handlers = new HandlerList();
+    private boolean cancelled;
+    private final PotionEffect effect;
+    private final Entity source;
+
+    /**
+     * @param entity the entity receiving the effect
+     * @param effect the potion effect being applied
+     * @param source the entity responsible for applying the effect, or null
+     *               (e.g. beacon, command, or plugin)
+     */
+    public PotionAddedEvent(LivingEntity entity, PotionEffect effect, Entity source) {
+        super(entity);
+        this.effect = effect;
+        this.source = source;
+    }
+
+    @Override
+    public LivingEntity getEntity() {
+        return (LivingEntity) entity;
+    }
+
+    /**
+     * Returns the potion effect that will be applied.
+     *
+     * @return the {@link PotionEffect}
+     */
+    public PotionEffect getEffect() {
+        return effect;
+    }
+
+    /**
+     * Returns the entity that caused this effect to be applied, or null if
+     * the source is non-entity (beacon, command, plugin API, etc.).
+     *
+     * @return the source {@link Entity}, or null
+     */
+    public Entity getSource() {
+        return source;
+    }
+
+    @Override
+    public boolean isCancelled() {
+        return cancelled;
+    }
+
+    @Override
+    public void setCancelled(boolean cancel) {
+        this.cancelled = cancel;
+    }
+
+    @Override
+    public HandlerList getHandlers() {
+        return handlers;
+    }
+
+    public static HandlerList getHandlerList() {
+        return handlers;
+    }
+}
diff --git a/src/main/java/org/bukkit/event/entity/PotionRemovedEvent.java b/src/main/java/org/bukkit/event/entity/PotionRemovedEvent.java
new file mode 100644
index 0000000000000000000000000000000000000000..88fff733015faa92df165bcb928f7e39c6c65c65
--- /dev/null
+++ b/src/main/java/org/bukkit/event/entity/PotionRemovedEvent.java
@@ -0,0 +1,52 @@
+package org.bukkit.event.entity;
+
+import org.bukkit.entity.LivingEntity;
+import org.bukkit.event.HandlerList;
+import org.bukkit.potion.PotionEffect;
+
+/**
+ * Called after a potion effect has been removed from a living entity,
+ * either because it expired naturally or was removed programmatically.
+ * <p>
+ * The effect has already been removed from the entity when this event fires.
+ * {@link #getEffect()} reflects the state of the effect at the moment of removal
+ * (e.g. remaining duration is 0 for natural expiry).
+ */
+public class PotionRemovedEvent extends EntityEvent {
+
+    private static final HandlerList handlers = new HandlerList();
+    private final PotionEffect effect;
+
+    /**
+     * @param entity the entity that lost the effect
+     * @param effect the potion effect that was removed
+     */
+    public PotionRemovedEvent(LivingEntity entity, PotionEffect effect) {
+        super(entity);
+        this.effect = effect;
+    }
+
+    @Override
+    public LivingEntity getEntity() {
+        return (LivingEntity) entity;
+    }
+
+    /**
+     * Returns the potion effect that was removed, with its state at the time
+     * of removal (remaining duration may be 0 if it expired naturally).
+     *
+     * @return the removed {@link PotionEffect}
+     */
+    public PotionEffect getEffect() {
+        return effect;
+    }
+
+    @Override
+    public HandlerList getHandlers() {
+        return handlers;
+    }
+
+    public static HandlerList getHandlerList() {
+        return handlers;
+    }
+}
diff --git a/src/main/java/org/bukkit/event/fakeplayer/FakePlayerAttackEvent.java b/src/main/java/org/bukkit/event/fakeplayer/FakePlayerAttackEvent.java
