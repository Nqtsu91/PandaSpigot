+package org.bukkit.event.fakeplayer;
+
+import org.bukkit.entity.Player;
+import org.bukkit.event.Cancellable;
+import org.bukkit.event.Event;
+import org.bukkit.event.HandlerList;
+
+/**
+ * Fired when a FakePlayer is about to begin eating a golden apple.
+ *
+ * <p>This event fires at the <em>start</em> of the eating sequence (before the
+ * 32-tick animation begins), not when effects are applied.  Cancelling it
+ * prevents the eat entirely — no animation plays, no golden apple is consumed,
+ * and the stock count is unchanged.</p>
+ */
+public class FakePlayerEatEvent extends Event implements Cancellable {
+
+    private static final HandlerList handlers = new HandlerList();
+    private boolean cancelled;
+
+    private final Player fakePlayer;
+    /**
+     * Number of golden apples that will remain after this eat completes
+     * (i.e. current count − 1).
+     */
+    private final int gapplesRemaining;
+
+    public FakePlayerEatEvent(Player fakePlayer, int gapplesRemaining) {
+        this.fakePlayer       = fakePlayer;
+        this.gapplesRemaining = gapplesRemaining;
+    }
+
+    /** Returns the FakePlayer that is about to eat. */
+    public Player getFakePlayer() { return fakePlayer; }
+
+    /**
+     * Returns how many golden apples will remain after this eat completes
+     * (current count − 1).  If the event is cancelled, the count stays at
+     * {@code gapplesRemaining + 1}.
+     */
+    public int getGapplesRemaining() { return gapplesRemaining; }
+
+    @Override public boolean isCancelled()           { return cancelled; }
+    @Override public void    setCancelled(boolean c) { this.cancelled = c; }
+    @Override public HandlerList getHandlers()       { return handlers; }
+    public static  HandlerList   getHandlerList()    { return handlers; }
+}
