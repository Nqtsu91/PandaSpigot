diff --git a/src/main/java/org/bukkit/event/entity/EntityThornsEvent.java b/src/main/java/org/bukkit/event/entity/EntityThornsEvent.java
new file mode 100644
index 0000000000000000000000000000000000000000..e909ac71fbdd341359a0e0e078b0f391a1541c4c
--- /dev/null
+++ b/src/main/java/org/bukkit/event/entity/EntityThornsEvent.java
@@ -0,0 +1,93 @@
+package org.bukkit.event.entity;
+
+import org.bukkit.entity.Entity;
+import org.bukkit.entity.LivingEntity;
+import org.bukkit.event.Cancellable;
+import org.bukkit.event.HandlerList;
+
+/**
+ * Fired when the Thorns enchantment on a defender's armor is about to reflect damage
+ * onto an attacker, exposing the activation chance and reflected damage so plugins can
+ * tune, disable, or force the effect per hit.
+ *
+ * <p>Defaults reproduce vanilla exactly (chance {@code 0.15 × level}, damage
+ * {@code level > 10 ? level - 10 : 1..4}); if no listener changes anything the behaviour
+ * is identical to unmodified Minecraft, so this event does not affect other plugins.
+ *
+ * <ul>
+ *   <li>{@link #setActivationChance(float)} — probability (0–1) that thorns triggers.</li>
+ *   <li>{@link #setReflectedDamage(float)} — damage dealt back to the attacker on trigger.</li>
+ *   <li>Cancelling skips thorns entirely for this hit (only armor durability is spent).</li>
+ * </ul>
+ */
+public class EntityThornsEvent extends EntityEvent implements Cancellable {
+
+    private static final HandlerList handlers = new HandlerList();
+
+    private final Entity attacker;
+    private final int    level;
+    private float        activationChance;
+    private float        reflectedDamage;
+    private boolean      cancelled;
+
+    public EntityThornsEvent(LivingEntity defender, Entity attacker, int level,
+                             float activationChance, float reflectedDamage) {
+        super(defender);
+        this.attacker         = attacker;
+        this.level            = level;
+        this.activationChance = activationChance;
+        this.reflectedDamage  = reflectedDamage;
+    }
+
+    /** The entity wearing the Thorns armor (the one reflecting the damage). */
+    public LivingEntity getDefender() {
+        return (LivingEntity) entity;
+    }
+
+    /** The entity that would receive the reflected damage. May be {@code null}. */
+    public Entity getAttacker() {
+        return attacker;
+    }
+
+    /** The combined Thorns level across the defender's armor. */
+    public int getLevel() {
+        return level;
+    }
+
+    /** Probability in [0, 1] that Thorns triggers on this hit. */
+    public float getActivationChance() {
+        return activationChance;
+    }
+
+    public void setActivationChance(float activationChance) {
+        this.activationChance = Math.max(0f, Math.min(1f, activationChance));
+    }
+
+    /** Damage reflected back to the attacker when Thorns triggers. */
+    public float getReflectedDamage() {
+        return reflectedDamage;
+    }
+
+    public void setReflectedDamage(float reflectedDamage) {
+        this.reflectedDamage = Math.max(0f, reflectedDamage);
+    }
+
+    @Override
+    public boolean isCancelled() {
+        return cancelled;
+    }
+
+    @Override
+    public void setCancelled(boolean cancel) {
+        this.cancelled = cancel;
+    }
+
+    @Override
+    public HandlerList getHandlers() {
+        return handlers;
+    }
+
+    public static HandlerList getHandlerList() {
+        return handlers;
+    }
+}
diff --git a/src/main/java/org/bukkit/event/entity/PlayerFatalHitEvent.java b/src/main/java/org/bukkit/event/entity/PlayerFatalHitEvent.java
new file mode 100644
index 0000000000000000000000000000000000000000..32d02efa877d832f1b6923f0d3cc331fdacd8018
--- /dev/null
+++ b/src/main/java/org/bukkit/event/entity/PlayerFatalHitEvent.java
@@ -0,0 +1,109 @@
+package org.bukkit.event.entity;
+
+import org.bukkit.entity.Entity;
+import org.bukkit.entity.Player;
+import org.bukkit.event.Cancellable;
+import org.bukkit.event.HandlerList;
+import org.bukkit.event.player.PlayerEvent;
+
+/**
+ * Fired when a player's health would reach zero, just before {@code die()} is called.
+ *
+ * <p>Cancelling this event keeps the player alive at {@link #getSurvivalHealth()} HP.
+ * Works for all damage sources (melee, arrows, environment, void, etc.).</p>
+ *
+ * <p>This event fires after {@link PlayerReceiveDamageEvent} and after
+ * {@link org.bukkit.event.entity.EntityDamageEvent}. The full damage breakdown
+ * is available from those earlier events.</p>
+ *
+ * <p>Works whether the player is ALIVE (normal death) — plugins managing their own
+ * death system (e.g. WeebAPI) should cancel this event to handle the transition
+ * themselves instead of relying on {@link EntityDamageEvent} priority hacks.</p>
+ */
+public class PlayerFatalHitEvent extends PlayerEvent implements Cancellable {
+
+    private static final HandlerList handlers = new HandlerList();
+
+    private boolean cancelled = false;
+
+    /**
+     * The entity that dealt the killing blow, or {@code null} for environmental causes
+     * (fall, void, drowning, etc.).
+     */
+    private final Entity killer;
+
+    /**
+     * The raw incoming damage value that reduced health to zero.
+     * This is the pre-reduction amount; the actual damage applied may be lower.
+     * Use {@link PlayerReceiveDamageEvent#getFinalDamage()} (fired earlier) for the
+     * post-reduction value.
+     */
+    private final float rawDamage;
+
+    /**
+     * Health the player will have if this event is cancelled.
+     * Default: 0.5F (¼ heart). Must be {@code > 0}.
+     */
+    private float survivalHealth = 0.5F;
+
+    public PlayerFatalHitEvent(Player player, Entity killer, float rawDamage) {
+        super(player);
+        this.killer = killer;
+        this.rawDamage = rawDamage;
+    }
+
+    /**
+     * Returns the entity responsible for the fatal hit, or {@code null} if the cause
+     * is environmental (void, poison, fire, fall, etc.).
+     */
+    public Entity getKiller() {
+        return killer;
+    }
+
+    /**
+     * Returns the raw (pre-reduction) damage that triggered this fatal hit.
+     */
+    public float getRawDamage() {
+        return rawDamage;
+    }
+
+    /**
+     * Returns the health the player will be set to if this event is cancelled.
+     * Default is {@code 0.5F}.
+     */
+    public float getSurvivalHealth() {
+        return survivalHealth;
+    }
+
+    /**
+     * Sets the health the player will have if this event is cancelled.
+     *
+     * @param health must be {@code > 0}
+     * @throws IllegalArgumentException if health ≤ 0
+     */
+    public void setSurvivalHealth(float health) {
+        if (health <= 0.0F) {
+            throw new IllegalArgumentException("survivalHealth must be > 0, got: " + health);
+        }
+        this.survivalHealth = health;
+    }
+
+    @Override
+    public boolean isCancelled() {
+        return cancelled;
+    }
+
+    @Override
+    public void setCancelled(boolean cancel) {
+        this.cancelled = cancel;
+    }
+
+    @Override
+    public HandlerList getHandlers() {
+        return handlers;
+    }
+
+    public static HandlerList getHandlerList() {
+        return handlers;
+    }
+}
diff --git a/src/main/java/org/bukkit/event/entity/PlayerReceiveDamageEvent.java b/src/main/java/org/bukkit/event/entity/PlayerReceiveDamageEvent.java
new file mode 100644
index 0000000000000000000000000000000000000000..28a41aab7465e1b7364f45a2c598c8af921aa3bc
--- /dev/null
+++ b/src/main/java/org/bukkit/event/entity/PlayerReceiveDamageEvent.java
@@ -0,0 +1,297 @@
+package org.bukkit.event.entity;
+
+import java.util.function.Supplier;
+import org.bukkit.entity.Entity;
+import org.bukkit.entity.Player;
+import org.bukkit.event.Cancellable;
+import org.bukkit.event.HandlerList;
+
+/**
+ * Fired when a player is about to receive damage, exposing every individual
+ * component of the damage calculation formula so that plugins can modify each
+ * value independently.
+ *
+ * <h3>Damage formula</h3>
+ * <pre>
+ *   finalDamage = rawIncomingDamage
+ *               - hardHatReduction
+ *               - blockingReduction
+ *               - armorReduction
+ *               - resistanceReduction
+ *               - magicReduction
+ *               - absorptionReduction
+ *   (result is clamped to 0)
+ * </pre>
+ *
+ * <h3>When the attacker is a player, extra read-only breakdown fields are available:</h3>
+ * <ul>
+ *   <li>{@link #getAttackerBaseDamage()} — raw attack attribute value (pre-crit)</li>
+ *   <li>{@link #getAttackerEnchantmentBonus()} — sharpness / smite / etc.</li>
+ *   <li>{@link #wasAttackerCritical()} — whether the hit was a crit</li>
+ *   <li>{@link #getAttackerCriticalMultiplier()} — crit multiplier (vanilla 1.5)</li>
+ *   <li>{@link #getAttackerKnockbackLevel()} — knockback level</li>
+ * </ul>
+ * These are informational; to change the effective incoming damage, set
+ * {@link #setRawIncomingDamage(float)} directly.
+ *
+ * <p>This event fires BEFORE {@link EntityDamageEvent}. If not cancelled, the
+ * (potentially modified) values are forwarded to {@code EntityDamageEvent} for
+ * further processing by other plugins.
+ */
+public class PlayerReceiveDamageEvent extends EntityEvent implements Cancellable {
+
+    /**
+     * Approximate body part that was struck, based on the height of the
+     * attacker's eyes relative to the victim's bounding box.
+     *
+     * <p>Only computed on the first call to {@link PlayerReceiveDamageEvent#getHitLocation()};
+     * {@code UNKNOWN} is returned when no attacker position is available.
+     */
+    public enum HitLocation {
+        HEAD,
+        TORSO,
+        LEGS,
+        FEET,
+        /** Returned when the hit location cannot be determined (no melee attacker, etc.). */
+        UNKNOWN
+    }
+
+    private static final HandlerList handlers = new HandlerList();
+    private boolean cancelled;
+
+    // Source
+    private final Entity source;
+
+    // ---- Attacker breakdown (read-only, only populated for player melee) ----
+    private final boolean fromPlayerAttack;
+    private final float attackerBaseDamage;
+    private final float attackerEnchantmentBonus;
+    private final boolean attackerCritical;
+    private final float attackerCriticalMultiplier;
+    private final int attackerKnockbackLevel;
+
+    // ---- Primary damage value ----
+    private float rawIncomingDamage;
+
+    // ---- Defense reductions (positive = amount absorbed, min 0) ----
+    private float hardHatReduction;
+    private float blockingReduction;
+    private float armorReduction;
+    private float resistanceReduction;
+    private float magicReduction;
+    private float absorptionReduction;
+
+    // ---- Hit location (lazy) ----
+    private final Supplier<HitLocation> hitLocationSupplier;
+    private HitLocation hitLocation = null;
+
+    public PlayerReceiveDamageEvent(Player victim,
+                                    Entity source,
+                                    float rawIncomingDamage,
+                                    float hardHatReduction,
+                                    float blockingReduction,
+                                    float armorReduction,
+                                    float resistanceReduction,
+                                    float magicReduction,
+                                    float absorptionReduction,
+                                    boolean fromPlayerAttack,
+                                    float attackerBaseDamage,
+                                    float attackerEnchantmentBonus,
+                                    boolean attackerCritical,
+                                    float attackerCriticalMultiplier,
+                                    int attackerKnockbackLevel,
+                                    Supplier<HitLocation> hitLocationSupplier) {
+        super(victim);
+        this.source                    = source;
+        this.rawIncomingDamage         = rawIncomingDamage;
+        this.hardHatReduction          = Math.max(0, hardHatReduction);
+        this.blockingReduction         = Math.max(0, blockingReduction);
+        this.armorReduction            = Math.max(0, armorReduction);
+        this.resistanceReduction       = Math.max(0, resistanceReduction);
+        this.magicReduction            = Math.max(0, magicReduction);
+        this.absorptionReduction       = Math.max(0, absorptionReduction);
+        this.fromPlayerAttack          = fromPlayerAttack;
+        this.attackerBaseDamage        = attackerBaseDamage;
+        this.attackerEnchantmentBonus  = attackerEnchantmentBonus;
+        this.attackerCritical          = attackerCritical;
+        this.attackerCriticalMultiplier = attackerCriticalMultiplier;
+        this.attackerKnockbackLevel    = attackerKnockbackLevel;
+        this.hitLocationSupplier       = hitLocationSupplier;
+    }
+
+    // -------------------------------------------------------------------------
+    // Entity / source
+    // -------------------------------------------------------------------------
+
+    @Override
+    public Player getEntity() {
+        return (Player) entity;
+    }
+
+    /**
+     * Returns the entity that dealt the damage, or {@code null} for
+     * environmental sources (fall damage, lava, etc.).
+     */
+    public Entity getSource() {
+        return source;
+    }
+
+    // -------------------------------------------------------------------------
+    // Attacker breakdown (read-only, only meaningful when fromPlayerAttack)
+    // -------------------------------------------------------------------------
+
+    /** Returns {@code true} if the damage originates from a direct player melee attack. */
+    public boolean isFromPlayerAttack() {
+        return fromPlayerAttack;
+    }
+
+    /**
+     * The attacker's raw attack-damage attribute value before the critical
+     * multiplier was applied.
+     * Only meaningful when {@link #isFromPlayerAttack()} is {@code true}.
+     */
+    public float getAttackerBaseDamage() {
+        return attackerBaseDamage;
+    }
+
+    /**
+     * The bonus damage added by weapon enchantments (Sharpness, Smite, etc.).
+     * Only meaningful when {@link #isFromPlayerAttack()} is {@code true}.
+     */
+    public float getAttackerEnchantmentBonus() {
+        return attackerEnchantmentBonus;
+    }
+
+    /**
+     * Whether the attack was a critical hit.
+     * Only meaningful when {@link #isFromPlayerAttack()} is {@code true}.
+     */
+    public boolean wasAttackerCritical() {
+        return attackerCritical;
+    }
+
+    /**
+     * The critical-hit multiplier applied to the base damage (vanilla: 1.5).
+     * Only meaningful when {@link #isFromPlayerAttack()} is {@code true}.
+     */
+    public float getAttackerCriticalMultiplier() {
+        return attackerCriticalMultiplier;
+    }
+
+    /**
+     * The knockback level on this hit (from enchantment + sprint bonus).
+     * Only meaningful when {@link #isFromPlayerAttack()} is {@code true}.
+     */
+    public int getAttackerKnockbackLevel() {
+        return attackerKnockbackLevel;
+    }
+
+    // -------------------------------------------------------------------------
+    // Primary incoming damage
+    // -------------------------------------------------------------------------
+
+    /**
+     * Returns the raw damage before any defensive reductions.
+     * For player attacks this equals {@code baseDamage × critMult + enchantBonus}.
+     */
+    public float getRawIncomingDamage() {
+        return rawIncomingDamage;
+    }
+
+    /**
+     * Overrides the raw incoming damage that feeds into all defense calculations.
+     * Set this to change how much damage the player effectively received before
+     * armor/resistance/etc. are applied.
+     *
+     * @param rawIncomingDamage non-negative raw damage value
+     */
+    public void setRawIncomingDamage(float rawIncomingDamage) {
+        this.rawIncomingDamage = Math.max(0, rawIncomingDamage);
+    }
+
+    // -------------------------------------------------------------------------
+    // Defense reductions
+    // -------------------------------------------------------------------------
+
+    /** Damage absorbed by the helmet when struck by an anvil or falling block. */
+    public float getHardHatReduction() { return hardHatReduction; }
+    public void setHardHatReduction(float v) { this.hardHatReduction = Math.max(0, v); }
+
+    /** Damage absorbed by blocking with a sword. */
+    public float getBlockingReduction() { return blockingReduction; }
+    public void setBlockingReduction(float v) { this.blockingReduction = Math.max(0, v); }
+
+    /** Damage absorbed by worn armor. */
+    public float getArmorReduction() { return armorReduction; }
+    public void setArmorReduction(float v) { this.armorReduction = Math.max(0, v); }
+
+    /** Damage absorbed by the Resistance potion effect. */
+    public float getResistanceReduction() { return resistanceReduction; }
+    public void setResistanceReduction(float v) { this.resistanceReduction = Math.max(0, v); }
+
+    /** Damage absorbed by Protection / Blast Protection / etc. enchantments. */
+    public float getMagicReduction() { return magicReduction; }
+    public void setMagicReduction(float v) { this.magicReduction = Math.max(0, v); }
+
+    /** Damage absorbed by Absorption hearts. */
+    public float getAbsorptionReduction() { return absorptionReduction; }
+    public void setAbsorptionReduction(float v) { this.absorptionReduction = Math.max(0, v); }
+
+    // -------------------------------------------------------------------------
+    // Final damage
+    // -------------------------------------------------------------------------
+
+    /**
+     * Returns the damage that will be applied to the player's health after all
+     * reductions.  This value is read-only; to change the outcome modify the
+     * individual components above.
+     */
+    public float getFinalDamage() {
+        return Math.max(0,
+                rawIncomingDamage
+                - hardHatReduction
+                - blockingReduction
+                - armorReduction
+                - resistanceReduction
+                - magicReduction
+                - absorptionReduction);
+    }
+
+    // -------------------------------------------------------------------------
+    // Hit location (lazy)
+    // -------------------------------------------------------------------------
+
+    /**
+     * Returns the approximate body part that was struck.
+     *
+     * <p>The value is computed on the <strong>first call</strong> to this method
+     * (using the attacker's eye height relative to the victim's bounding box) and
+     * then cached for subsequent calls.
+     *
+     * <p>Returns {@link HitLocation#UNKNOWN} when the damage has no positional
+     * attacker (fall damage, fire, etc.) or when no position data is available.
+     *
+     * @return the hit location, never {@code null}
+     */
+    public HitLocation getHitLocation() {
+        if (hitLocation == null) {
+            hitLocation = hitLocationSupplier.get();
+        }
+        return hitLocation;
+    }
+
+    // -------------------------------------------------------------------------
+    // Cancellable / HandlerList
+    // -------------------------------------------------------------------------
+
+    @Override
+    public boolean isCancelled() { return cancelled; }
+
+    @Override
+    public void setCancelled(boolean cancel) { this.cancelled = cancel; }
+
+    @Override
+    public HandlerList getHandlers() { return handlers; }
+
+    public static HandlerList getHandlerList() { return handlers; }
+}
diff --git a/src/main/java/org/bukkit/event/entity/PotionAddedEvent.java b/src/main/java/org/bukkit/event/entity/PotionAddedEvent.java
