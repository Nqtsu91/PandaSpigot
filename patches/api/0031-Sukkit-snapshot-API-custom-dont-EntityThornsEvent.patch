+package org.bukkit.event.fakeplayer;
+
+import org.bukkit.entity.Entity;
+import org.bukkit.entity.Player;
+import org.bukkit.event.Cancellable;
+import org.bukkit.event.Event;
+import org.bukkit.event.HandlerList;
+
+/**
+ * Fired when a FakePlayer is about to die.
+ *
+ * <p>Cancelling this event prevents death: the FakePlayer remains alive with
+ * whatever health it currently has.  Plugins that cancel this event should
+ * restore HP to avoid an instant-death loop on the next tick.</p>
+ */
+public class FakePlayerDeathEvent extends Event implements Cancellable {
+
+    private static final HandlerList handlers = new HandlerList();
+    private boolean cancelled;
+
+    private final Player fakePlayer;
+    /** The entity that dealt the killing blow, or {@code null} for environmental causes. */
+    private final Entity killer;
+
+    public FakePlayerDeathEvent(Player fakePlayer, Entity killer) {
+        this.fakePlayer = fakePlayer;
+        this.killer     = killer;
+    }
+
+    /** Returns the FakePlayer that is about to die. */
+    public Player getFakePlayer() { return fakePlayer; }
+
+    /**
+     * Returns the entity that dealt the killing blow, or {@code null} if the
+     * cause was environmental (fall damage, fire, void, etc.).
+     */
+    public Entity getKiller() { return killer; }
+
+    @Override public boolean isCancelled()           { return cancelled; }
+    @Override public void    setCancelled(boolean c) { this.cancelled = c; }
+    @Override public HandlerList getHandlers()       { return handlers; }
+    public static  HandlerList   getHandlerList()    { return handlers; }
+}
