+package org.bukkit.event.fakeplayer;
+
+import org.bukkit.entity.LivingEntity;
+import org.bukkit.entity.Player;
+import org.bukkit.event.Cancellable;
+import org.bukkit.event.Event;
+import org.bukkit.event.HandlerList;
+
+/**
+ * Fired when a FakePlayer's AI is about to execute a melee swing at its target.
+ *
+ * <p>Cancelling this event suppresses both the arm-swing animation and the
+ * {@code attack()} call — no damage is dealt and no knockback is applied.
+ * The attack cooldown is NOT reset when cancelled, so the bot will attempt
+ * again on the next eligible tick.</p>
+ */
+public class FakePlayerAttackEvent extends Event implements Cancellable {
+
+    private static final HandlerList handlers = new HandlerList();
+    private boolean cancelled;
+
+    private final Player      fakePlayer;
+    private final LivingEntity target;
+
+    public FakePlayerAttackEvent(Player fakePlayer, LivingEntity target) {
+        this.fakePlayer = fakePlayer;
+        this.target     = target;
+    }
+
+    /** Returns the FakePlayer that is about to swing. */
+    public Player getFakePlayer() { return fakePlayer; }
+
+    /** Returns the entity that the FakePlayer is targeting. */
+    public LivingEntity getTarget() { return target; }
+
+    @Override public boolean isCancelled()           { return cancelled; }
+    @Override public void    setCancelled(boolean c) { this.cancelled = c; }
+    @Override public HandlerList getHandlers()       { return handlers; }
+    public static  HandlerList   getHandlerList()    { return handlers; }
+}
