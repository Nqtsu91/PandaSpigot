+++ b/src/main/java/org/bukkit/event/fakeplayer/FakePlayerDamagedEvent.java
@@ -0,0 +1,58 @@
+package org.bukkit.event.fakeplayer;
+
+import org.bukkit.entity.Entity;
+import org.bukkit.entity.Player;
+import org.bukkit.event.Cancellable;
+import org.bukkit.event.Event;
+import org.bukkit.event.HandlerList;
+
+/**
+ * Fired when a FakePlayer is about to take damage from any source.
+ *
+ * <p>The raw {@link #getDamage()} value is the damage <em>before</em> any
+ * armor, resistance, or absorption reductions.  Modifying it via
+ * {@link #setDamage(float)} adjusts what reaches the full damage pipeline.</p>
+ *
+ * <p>Cancelling this event prevents the damage entirely (the FakePlayer
+ * takes 0 damage and no knockback is applied).</p>
+ */
+public class FakePlayerDamagedEvent extends Event implements Cancellable {
+
+    private static final HandlerList handlers = new HandlerList();
+    private boolean cancelled;
+
+    private final Player fakePlayer;
+    private float        damage;
+    /** Entity that dealt the damage, or {@code null} for environmental sources. */
+    private final Entity attacker;
+
+    public FakePlayerDamagedEvent(Player fakePlayer, float damage, Entity attacker) {
+        this.fakePlayer = fakePlayer;
+        this.damage     = Math.max(0, damage);
+        this.attacker   = attacker;
+    }
+
+    /** Returns the FakePlayer that is about to take damage. */
+    public Player getFakePlayer() { return fakePlayer; }
+
+    /** Returns the raw incoming damage value (before defense reductions). */
+    public float getDamage() { return damage; }
+
+    /**
+     * Overrides the raw incoming damage value fed into the defense pipeline.
+     *
+     * @param damage non-negative value; clamped to 0 if negative
+     */
+    public void setDamage(float damage) { this.damage = Math.max(0, damage); }
+
+    /**
+     * Returns the entity that dealt the damage, or {@code null} for
+     * environmental sources (fall, fire, void, etc.).
+     */
+    public Entity getAttacker() { return attacker; }
+
+    @Override public boolean isCancelled()           { return cancelled; }
+    @Override public void    setCancelled(boolean c) { this.cancelled = c; }
+    @Override public HandlerList getHandlers()       { return handlers; }
+    public static  HandlerList   getHandlerList()    { return handlers; }
+}
