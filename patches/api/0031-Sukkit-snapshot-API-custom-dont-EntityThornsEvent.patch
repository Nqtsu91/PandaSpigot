diff --git a/src/main/java/org/bukkit/event/player/PlayerArmorChangeEvent.java b/src/main/java/org/bukkit/event/player/PlayerArmorChangeEvent.java
new file mode 100644
index 0000000000000000000000000000000000000000..8970f5b85a664ccaedb7ac75af509b2b9ad3e25d
--- /dev/null
+++ b/src/main/java/org/bukkit/event/player/PlayerArmorChangeEvent.java
@@ -0,0 +1,141 @@
+package org.bukkit.event.player;
+
+import org.bukkit.entity.Player;
+import org.bukkit.event.Cancellable;
+import org.bukkit.event.HandlerList;
+import org.bukkit.inventory.ItemStack;
+
+/**
+ * Fired when a player's armor inventory changes — equip, unequip, slot swap, break, or death.
+ *
+ * <h3>Cancellation</h3>
+ * Cancellable for {@link ChangeReason#PLAYER} and {@link ChangeReason#PLUGIN} only.
+ * {@link ChangeReason#BREAK} and {@link ChangeReason#DEATH} are purely informational and
+ * cannot be cancelled (the change has already been committed).
+ *
+ * <h3>WeebBinding</h3>
+ * Items with the {@code WeebBinding} NBT byte set to 1 are never removable by the player
+ * ({@link ChangeReason#PLAYER} change is silently blocked before this event fires).
+ * They can still be replaced by plugin code ({@link ChangeReason#PLUGIN}) and are
+ * naturally removed on break ({@link ChangeReason#BREAK}) or death ({@link ChangeReason#DEATH}).
+ *
+ * <h3>WeebEffects NBT format</h3>
+ * Armor items may carry a {@code WeebEffects} NBT list of the form:
+ * <pre>
+ * WeebEffects: [
+ *   { Id: 1b, Amplifier: 0b }   // Speed I
+ *   { Id: 5b, Amplifier: 1b }   // Strength II
+ * ]
+ * </pre>
+ * Effects are applied automatically to the wearing player and removed when the armor is
+ * no longer equipped.
+ */
+public class PlayerArmorChangeEvent extends PlayerEvent implements Cancellable {
+
+    private static final HandlerList handlers = new HandlerList();
+
+    // -------------------------------------------------------------------------
+    // Nested enums
+    // -------------------------------------------------------------------------
+
+    /**
+     * Which armor slot changed.
+     * The {@link #getIndex()} value matches {@code PlayerInventory.armor[index]}.
+     */
+    public enum Slot {
+        BOOTS(0), LEGGINGS(1), CHESTPLATE(2), HELMET(3);
+
+        private final int index;
+
+        Slot(int index) { this.index = index; }
+
+        /** Raw index into {@code PlayerInventory.armor[]}. */
+        public int getIndex() { return index; }
+
+        public static Slot fromIndex(int index) {
+            for (Slot s : values()) {
+                if (s.index == index) return s;
+            }
+            throw new IllegalArgumentException("Invalid armor index: " + index);
+        }
+    }
+
+    public enum ChangeReason {
+        /**
+         * The player manually moved the item via the inventory UI (drag, shift-click, etc.).
+         * Cancellable. WeebBinding is enforced before this event fires.
+         */
+        PLAYER,
+
+        /**
+         * Set programmatically via a plugin or WeebAPI internal call.
+         * Cancellable. WeebBinding is NOT enforced (plugin has higher authority).
+         */
+        PLUGIN,
+
+        /**
+         * Armor durability reached 0. The slot has already been cleared.
+         * Not cancellable — the change is already committed.
+         */
+        BREAK,
+
+        /**
+         * Player died and the inventory was cleared.
+         * Not cancellable — the change is already committed.
+         */
+        DEATH
+    }
+
+    // -------------------------------------------------------------------------
+    // Instance fields
+    // -------------------------------------------------------------------------
+
+    private final Slot          slot;
+    private final ItemStack     oldItem;   // may be null
+    private final ItemStack     newItem;   // may be null
+    private final ChangeReason  reason;
+    private       boolean       cancelled = false;
+
+    public PlayerArmorChangeEvent(Player player, Slot slot,
+                                  ItemStack oldItem, ItemStack newItem,
+                                  ChangeReason reason) {
+        super(player);
+        this.slot    = slot;
+        this.oldItem = oldItem;
+        this.newItem = newItem;
+        this.reason  = reason;
+    }
+
+    // -------------------------------------------------------------------------
+    // Accessors
+    // -------------------------------------------------------------------------
+
+    public Slot         getSlot()    { return slot; }
+    /** Item that was in the slot before the change, or {@code null} if the slot was empty. */
+    public ItemStack    getOldItem() { return oldItem; }
+    /** Item that will occupy the slot after the change, or {@code null} if the slot is being emptied. */
+    public ItemStack    getNewItem() { return newItem; }
+    public ChangeReason getReason()  { return reason; }
+
+    // -------------------------------------------------------------------------
+    // Cancellable
+    // -------------------------------------------------------------------------
+
+    @Override
+    public boolean isCancelled() { return cancelled; }
+
+    @Override
+    public void setCancelled(boolean cancel) {
+        // BREAK and DEATH are committed before the event fires — cancellation is a no-op
+        if (reason == ChangeReason.BREAK || reason == ChangeReason.DEATH) return;
+        this.cancelled = cancel;
+    }
+
+    // -------------------------------------------------------------------------
+    // HandlerList (required by Bukkit)
+    // -------------------------------------------------------------------------
+
+    @Override
+    public HandlerList getHandlers()            { return handlers; }
+    public static HandlerList getHandlerList()  { return handlers; }
+}
diff --git a/src/main/java/org/bukkit/potion/PotionEfficiencyManager.java b/src/main/java/org/bukkit/potion/PotionEfficiencyManager.java
new file mode 100644
index 0000000000000000000000000000000000000000..e1df89b36e4a946b808ffd16662e3fc01c2bf6b2
--- /dev/null
+++ b/src/main/java/org/bukkit/potion/PotionEfficiencyManager.java
@@ -0,0 +1,198 @@
+package org.bukkit.potion;
+
+import java.util.Map;
+import java.util.UUID;
+import java.util.concurrent.ConcurrentHashMap;
+
+/**
+ * Manages per-player and global efficiency values for potion effects.
+ *
+ * <p>The efficiency is a <strong>raw value per amplifier level</strong> that replaces
+ * the vanilla coefficient for that effect. For example:
+ * <ul>
+ *   <li>{@code setGlobalEfficiency(DAMAGE_RESISTANCE, 0.2)} → each level of Resistance
+ *       reduces damage by 20% (Resistance I = 20%, Resistance II = 40%). This is vanilla.</li>
+ *   <li>{@code setGlobalEfficiency(DAMAGE_RESISTANCE, 0.5)} → Resistance I = 50% reduction.</li>
+ *   <li>{@code setPlayerEfficiency(uuid, DAMAGE_RESISTANCE, 0.1)} → that player only gets
+ *       10% reduction per level regardless of the global setting.</li>
+ * </ul>
+ *
+ * <p>When no efficiency is configured for a given (player, effect) pair the vanilla formula
+ * is used unchanged. The resolution order is:
+ * <ol>
+ *   <li>Player-specific override (if set)</li>
+ *   <li>Global override (if set)</li>
+ *   <li>{@code null} → vanilla behaviour</li>
+ * </ol>
+ *
+ * <p>Reference: vanilla per-level coefficients
+ * <pre>
+ *  DAMAGE_RESISTANCE  0.20  (20 % reduction per level)
+ *  SPEED              0.20  (movement speed per level)
+ *  SLOW               0.15  (movement speed reduction per level)
+ *  FAST_DIGGING       0.20  (dig speed fraction added per level)
+ *  SLOW_DIGGING       0.30  (dig speed multiplied by 0.3^(level))
+ *  INCREASE_DAMAGE    2.50  (attack damage attribute per level, op=2)
+ *  WEAKNESS           2.00  (attack damage reduction per level, op=0)
+ *  HEALTH_BOOST       4.00  (max health added per level)
+ *  ABSORPTION         4.00  (absorption hearts per level)
+ *  REGENERATION       1.00  (HP healed per tick per level)
+ *  POISON             1.00  (HP damaged per tick per level)
+ *  WITHER             1.00  (HP damaged per tick per level)
+ *  HEAL               4.00  (HP healed per application per level, instant)
+ *  HARM               6.00  (HP damaged per application per level, instant)
+ *  JUMP               0.10  (extra motY per level)
+ *  HUNGER             0.025 (exhaustion per tick per level)
+ *  SATURATION         1.00  (food levels restored per tick per level)
+ * </pre>
+ *
+ * <p>Thread-safe.
+ */
+public final class PotionEfficiencyManager {
+
+    private static final Map<Integer, Double> globalEfficiencies = new ConcurrentHashMap<>();
+    private static final Map<UUID, Map<Integer, Double>> playerEfficiencies = new ConcurrentHashMap<>();
+
+    private PotionEfficiencyManager() {}
+
+    // -------------------------------------------------------------------------
+    // Global
+    // -------------------------------------------------------------------------
+
+    /**
+     * Sets the global efficiency for an effect type.
+     * This value applies to all entities that do not have a player-specific override.
+     *
+     * @param type       the effect type
+     * @param efficiency raw value per amplifier level (see class javadoc for units)
+     */
+    public static void setGlobalEfficiency(PotionEffectType type, double efficiency) {
+        globalEfficiencies.put(type.getId(), efficiency);
+    }
+
+    /**
+     * Returns the configured global efficiency, or {@code null} if none is set
+     * (meaning vanilla behaviour will be used).
+     *
+     * @param type the effect type
+     * @return the global efficiency, or {@code null}
+     */
+    public static Double getGlobalEfficiency(PotionEffectType type) {
+        return globalEfficiencies.get(type.getId());
+    }
+
+    /**
+     * Removes the global efficiency override for an effect type, restoring vanilla behaviour
+     * for all entities that do not have a player-specific override.
+     *
+     * @param type the effect type
+     */
+    public static void clearGlobalEfficiency(PotionEffectType type) {
+        globalEfficiencies.remove(type.getId());
+    }
+
+    // -------------------------------------------------------------------------
+    // Per-player
+    // -------------------------------------------------------------------------
+
+    /**
+     * Sets a player-specific efficiency override for an effect type.
+     * Takes priority over the global setting for that player.
+     *
+     * @param playerUuid the UUID of the player
+     * @param type       the effect type
+     * @param efficiency raw value per amplifier level
+     */
+    public static void setPlayerEfficiency(UUID playerUuid, PotionEffectType type, double efficiency) {
+        playerEfficiencies
+                .computeIfAbsent(playerUuid, k -> new ConcurrentHashMap<>())
+                .put(type.getId(), efficiency);
+    }
+
+    /**
+     * Returns the player-specific efficiency override, or {@code null} if none is set.
+     * Does NOT fall back to the global value.
+     *
+     * @param playerUuid the UUID of the player
+     * @param type       the effect type
+     * @return the player override, or {@code null}
+     */
+    public static Double getPlayerEfficiency(UUID playerUuid, PotionEffectType type) {
+        Map<Integer, Double> map = playerEfficiencies.get(playerUuid);
+        return (map != null) ? map.get(type.getId()) : null;
+    }
+
+    /**
+     * Removes the player-specific override for one effect type.
+     * The player will then fall back to the global efficiency (or vanilla).
+     *
+     * @param playerUuid the UUID of the player
+     * @param type       the effect type
+     */
+    public static void clearPlayerEfficiency(UUID playerUuid, PotionEffectType type) {
+        Map<Integer, Double> map = playerEfficiencies.get(playerUuid);
+        if (map != null) {
+            map.remove(type.getId());
+            if (map.isEmpty()) {
